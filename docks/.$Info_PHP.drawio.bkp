        <mxCell id="H_WizwPM-RSi_TVYo-0Q-26" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="850" width="940" x="700" y="160" as="geometry" />
        </mxCell>
        <mxCell id="H_WizwPM-RSi_TVYo-0Q-7" parent="H_WizwPM-RSi_TVYo-0Q-26" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;width=180;height=30;" value="PDO&amp;nbsp;„PHP Data Objects“" vertex="1">
          <mxGeometry height="850" width="940" as="geometry" />
        </mxCell>
        <mxCell id="H_WizwPM-RSi_TVYo-0Q-8" parent="H_WizwPM-RSi_TVYo-0Q-26" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="PDO („PHP Data Objects“) ist eine moderne, einheitliche Datenbankschnittstelle in PHP, mit der du sicher, flexibel und datenbankunabhängig auf verschiedene SQL‑Datenbanken zugreifen kannst. Es ersetzt alte, unsichere mysql\_\*-Funktionen und bietet dir vor allem Prepared Statements, saubere Fehlerbehandlung und Portabilität." vertex="1">
          <mxGeometry height="90" width="430" x="20" y="50" as="geometry" />
        </mxCell>
        <mxCell id="H_WizwPM-RSi_TVYo-0Q-9" parent="H_WizwPM-RSi_TVYo-0Q-26" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="🔍 Was genau ist PDO?&lt;div&gt;&lt;ul&gt;&lt;li&gt;Abstraktionsschicht für Datenbankzugriffe &lt;br&gt;Du verwendest dieselben Methoden, egal ob MySQL/MariaDB, PostgreSQL, SQLite oder SQL Server.&lt;/li&gt;&lt;li&gt;Einheitliche API&lt;br&gt;Klassen wie PDO und PDOStatement funktionieren für alle unterstützten Datenbanken.&lt;/li&gt;&lt;li&gt;Kein SQL‑Abstraktionsframework&lt;br&gt;PDO schreibt deine SQL‑Queries nicht um – du schreibst weiterhin SQL für die jeweilige Datenbank.&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="430" x="20" y="160" as="geometry" />
        </mxCell>
        <mxCell id="H_WizwPM-RSi_TVYo-0Q-10" parent="H_WizwPM-RSi_TVYo-0Q-26" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="🔐 Warum PDO nutzen?&lt;div&gt;&lt;div&gt;Sicherheit&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Prepared Statements verhindern SQL‑Injection zuverlässig.&lt;/li&gt;&lt;li&gt;Automatische Maskierung von Parametern.&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Flexibilität&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Wechsel der Datenbank ohne kompletten Rewrite – nur der DSN‑String ändert sich.&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Saubere Fehlerbehandlung&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;PDO kann Fehler als Exceptions werfen, was Debugging und Logging erleichtert.&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="250" width="430" x="20" y="350" as="geometry" />
        </mxCell>
        <mxCell id="H_WizwPM-RSi_TVYo-0Q-14" parent="H_WizwPM-RSi_TVYo-0Q-26" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="🧩 Wie verbindet man sich mit PDO?&lt;div&gt;Ein typisches Beispiel für MySQL/MariaDB:#&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;$dsn = &#39;mysql:host=localhost;dbname=test;charset=utf8&#39;;&lt;/div&gt;&lt;div&gt;$user = &#39;root&#39;;&lt;/div&gt;&lt;div&gt;$pass = &#39;&#39;;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;$options = [&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; PDO::ATTR_ERRMODE =&amp;gt; PDO::ERRMODE_EXCEPTION,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; PDO::ATTR_DEFAULT_FETCH_MODE =&amp;gt; PDO::FETCH_ASSOC,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; PDO::ATTR_EMULATE_PREPARES =&amp;gt; false&lt;/div&gt;&lt;div&gt;];&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;$pdo = new PDO($dsn, $user, $pass, $options);&lt;/div&gt;&lt;/div&gt;&lt;div&gt;Dieses Beispiel folgt den empfohlenen Best Practices für Sicherheit und Fehlerbehandlung.&lt;/div&gt;" vertex="1">
          <mxGeometry height="240" width="430" x="490" y="50" as="geometry" />
        </mxCell>
        <mxCell id="H_WizwPM-RSi_TVYo-0Q-15" parent="H_WizwPM-RSi_TVYo-0Q-26" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="🛠️ Abfragen ausführen&lt;div&gt;Prepared Statement&lt;/div&gt;&lt;div&gt;&lt;div&gt;$stmt = $pdo-&amp;gt;prepare(&quot;SELECT * FROM users WHERE email = :email&quot;);&lt;/div&gt;&lt;div&gt;$stmt-&amp;gt;execute([&#39;email&#39; =&amp;gt; $email]);&lt;/div&gt;&lt;div&gt;$user = $stmt-&amp;gt;fetch();&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Direkte Query (weniger sicher)&lt;/div&gt;&lt;div&gt;&lt;div&gt;$rows = $pdo-&amp;gt;query(&quot;SELECT * FROM users&quot;)-&amp;gt;fetchAll();&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="430" x="490" y="320" as="geometry" />
        </mxCell>
        <mxCell id="H_WizwPM-RSi_TVYo-0Q-16" parent="H_WizwPM-RSi_TVYo-0Q-26" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="📦 Unterstützte Datenbanken&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Prepared Statement&lt;/span&gt;&lt;div&gt;&lt;div&gt;Typische PDO‑Treiber:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;MySQL/MariaDB&lt;/li&gt;&lt;li&gt;PostgreSQL&lt;/li&gt;&lt;li&gt;SQLite&lt;/li&gt;&lt;li&gt;SQL Server&lt;/li&gt;&lt;li&gt;Oracle&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="430" x="490" y="480" as="geometry" />
        </mxCell>
        <mxCell id="H_WizwPM-RSi_TVYo-0Q-17" parent="H_WizwPM-RSi_TVYo-0Q-26" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;strokeColor=#66FFB3;" value="&lt;div&gt;🧠 Kurz gesagt&lt;/div&gt;&lt;div&gt;&lt;div&gt;PDO ist der professionelle Standard für Datenbankzugriffe in PHP: sicher, sauber, portabel und modern. Wenn du heute ein PHP‑Projekt baust – egal ob klein oder groß – solltest du immer PDO verwenden.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Wenn du möchtest, kann ich dir auch zeigen:&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;wie du eine komplette Login‑Funktion mit PDO sicher aufbaust,&lt;/li&gt;&lt;li&gt;wie du eine eigene PDO‑Datenbankklasse schreibst,&lt;/li&gt;&lt;li&gt;oder wie du deine bestehende MySQLi‑Logik auf PDO umstellst.&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;Womit möchtest du weitermachen?&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="430" x="490" y="650" as="geometry" />
        </mxCell>
