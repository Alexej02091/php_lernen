: #d4d4d4;&quot;&gt;( &lt;/span&gt;&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&#39;DROP&#39;&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; , &lt;/span&gt;&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&#39;TRUNCATE&#39;&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; , &lt;/span&gt;&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color: #ff7b72;&quot;&gt;ALTER&lt;/span&gt;&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; , &lt;/span&gt;&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color: #ff7b72;&quot;&gt;INSERT&lt;/span&gt;&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; , &lt;/span&gt;&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color: #ff7b72;&quot;&gt;UPDATE&lt;/span&gt;&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; , &lt;/span&gt;&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color: #ff7b72;&quot;&gt;DELETE&lt;/span&gt;&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; , &lt;/span&gt;&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color: #ff7b72;&quot;&gt;CREATE&lt;/span&gt;&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&#39;&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; , &lt;/span&gt;&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&#39;START&#39;&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; , &lt;/span&gt;&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&#39;COMMIT&#39;&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; , &lt;/span&gt;&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&#39;ROLLBACK&#39;&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; );&lt;/span&gt;&lt;/