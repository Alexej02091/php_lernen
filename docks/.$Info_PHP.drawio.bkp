        <mxCell id="8DqQCMdmOc6HaifYVGUy-7" parent="8DqQCMdmOc6HaifYVGUy-48" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="🧠 3. Warum existieren überhaupt drei APIs?&lt;div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;mysql\_* war die erste API (1990er), aber unsicher → entfernt.&lt;/li&gt;&lt;li&gt;MySQLi („MySQL improved“) kam später als Übergangslösung.&lt;/li&gt;&lt;li&gt;PDO wurde entwickelt, um eine einheitliche, sichere, moderne Schnittstelle für alle SQL‑Datenbanken zu bieten.&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="150" width="340" x="360" y="440" as="geometry" />
        </mxCell>
        <mxCell id="8DqQCMdmOc6HaifYVGUy-8" parent="8DqQCMdmOc6HaifYVGUy-48" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="🥇 Welche API solltest du heute verwenden?&lt;div&gt;&lt;strong&gt;Ganz klar: PDO.&amp;nbsp;&lt;/strong&gt;Warum?&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;moderne, saubere API&lt;/li&gt;&lt;li&gt;echte Prepared Statements&lt;/li&gt;&lt;li&gt;funktioniert mit MySQL, PostgreSQL, SQLite usw.&lt;/li&gt;&lt;li&gt;bessere Fehlerbehandlung (Exceptions)&lt;/li&gt;&lt;li&gt;sicherer Standard für neue Projekte&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;MySQLi ist okay, aber PDO ist professioneller und flexibler.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
