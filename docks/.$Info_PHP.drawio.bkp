        <mxCell id="pKHLCEEhMPk__EJ80ix6-83" parent="pKHLCEEhMPk__EJ80ix6-81" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;fontSize=16;align=left;spacingLeft=5;verticalAlign=top;" value="Das &lt;code&gt;use&lt;/code&gt; in PHP ist ein &lt;strong&gt;Import‑Statement&lt;/strong&gt;.&lt;br&gt;Es holt eine Klasse aus einem Namespace in den aktuellen Gültigkeitsbereich, damit du sie &lt;strong&gt;kürzer und bequemer&lt;/strong&gt; verwenden kannst.&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Das bedeutet:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;PHP soll die Klasse AuthController aus dem Namespace&lt;br&gt;App\Controllers verfügbar machen.&lt;/li&gt;&lt;li&gt;Danach kannst du sie einfach mit AuthController verwenden,&lt;br&gt;statt jedes Mal den kompletten Namespace zu schreiben.&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
