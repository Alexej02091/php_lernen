        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-209" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🧩 Konkrete Empfehlung für dich&lt;/div&gt;&lt;div&gt;Da du gerade OOP lernst und dein Projekt überschaubar ist:&lt;/div&gt;&lt;div&gt;👉 Mach eine Extra‑Klasse, z. B. DataManager oder Repository.&amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;Diese Klasse bekommt deine PDO‑Instanz und hat Methoden wie:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;insertAdmin($name, $pass)&lt;/li&gt;&lt;li&gt;insertTestData()&lt;/li&gt;&lt;li&gt;insertFromDatenPhp()&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Damit bist du sauber, flexibel und professionell unterwegs.&lt;/div&gt;" vertex="1">
          <mxGeometry height="150" width="510" x="-2730" y="2640" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-210" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;strokeColor=#33FF33;" value="&lt;div&gt;Wenn du willst…&lt;/div&gt;&lt;div&gt;…kann ich dir helfen:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;die perfekte Struktur für dein Projekt zu bauen&lt;/li&gt;&lt;li&gt;dir zeigen, wie man daten.php sauber in die Klasse lädt&lt;/li&gt;&lt;li&gt;dir erklären, wie man Repository‑Pattern richtig einsetzt&lt;/li&gt;&lt;li&gt;oder dir ein Diagramm machen, wie die Klassen zusammenarbeiten&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Sag einfach, in welche Richtung du weitergehen möchtest.&lt;/div&gt;" vertex="1">
          <mxGeometry height="137" width="510" x="-2730" y="2813" as="geometry" />
        </mxCell>
