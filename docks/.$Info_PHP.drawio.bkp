        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-76" parent="oGzVnZ6ClYmYdJZ-8DAw-110" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🧠 Aber: Moderne PHP‑OOP nutzt sie nicht mehr überall&lt;/div&gt;&lt;div&gt;Früher:&lt;/div&gt;&lt;div&gt;Jede Property war private, und man hat automatisch Getter/Setter generiert.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Heute:&lt;/div&gt;&lt;div&gt;Man nutzt Getter/Setter nur wenn sie einen Zweck haben.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Beispiel:&lt;/div&gt;&lt;div&gt;Wenn eine Property nie validiert werden muss, nie berechnet wird, nie geschützt werden muss — warum dann Setter/Getter?&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="390" x="14" y="410" as="geometry" />
        </mxCell>
