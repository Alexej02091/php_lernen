        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-114" parent="oGzVnZ6ClYmYdJZ-8DAw-150" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🧱 Ein einfaches Beispiel&lt;/div&gt;&lt;div&gt;Ohne Validierung:&lt;/div&gt;&lt;div&gt;&lt;div style=&quot;color: rgb(187, 190, 191); background-color: rgb(18, 19, 20); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; line-height: 19px; white-space: pre;&quot;&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;$user&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;-&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: #d2a8ff;&quot;&gt;setAge&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;(-&lt;/span&gt;&lt;span style=&quot;color: #b5cea8;&quot;&gt;5&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;); &lt;/span&gt;&lt;span style=&quot;color: #8b949e;&quot;&gt;// Alter -5? Unsinn, aber ohne Validierung passiert es!&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 19px; color: rgb(187, 190, 191); background-color: rgb(18, 19, 20);&quot;&gt;&lt;span style=&quot;color: rgb(139, 148, 158);&quot;&gt;Mit Validierung:&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 19px; color: rgb(187, 190, 191); background-color: rgb(18, 19, 20);&quot;&gt;&lt;span style=&quot;color: rgb(139, 148, 158);&quot;&gt;&lt;div style=&quot;color: rgb(187, 190, 191); background-color: rgb(18, 19, 20); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; line-height: 19px; white-space: pre;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;public&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #ff7b72;&quot;&gt;function&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d2a8ff;&quot;&gt;setAge&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #ff7b72;&quot;&gt;int&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;$age&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;) {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #c586c0;&quot;&gt;if&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; (&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;$age&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; &amp;lt; &lt;/span&gt;&lt;span style=&quot;color: #b5cea8;&quot;&gt;0&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;) {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #c586c0;&quot;&gt;throw&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #ff7b72;&quot;&gt;new&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;Exception&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;Alter kann nicht negativ sein&quot;&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;&amp;nbsp; &amp;nbsp; }&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #79c0ff;&quot;&gt;$this&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;-&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;age&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; = &lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;$age&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;}&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 19px; color: rgb(187, 190, 191); background-color: rgb(18, 19, 20);&quot;&gt;&lt;span style=&quot;color: rgb(139, 148, 158);&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 19px; color: rgb(187, 190, 191); background-color: rgb(18, 19, 20);&quot;&gt;&lt;span style=&quot;color: rgb(139, 148, 158);&quot;&gt;Jetzt ist dein Objekt immer in einem sinnvollen Zustand.&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="230" width="580" x="10" y="235" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-115" parent="oGzVnZ6ClYmYdJZ-8DAw-150" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🧠 Warum ist Validierung so wichtig?&lt;/div&gt;&lt;div&gt;Weil du damit:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Fehler früh abfängst&lt;/li&gt;&lt;li&gt;Logikfehler verhinderst&lt;/li&gt;&lt;li&gt;dein Objekt stabil hältst&lt;/li&gt;&lt;li&gt;Bugs reduzierst&lt;/li&gt;&lt;li&gt;Sicherheit erhöhst&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Ein Objekt ohne Validierung ist wie ein Haus ohne Fundament.&lt;/div&gt;" vertex="1">
