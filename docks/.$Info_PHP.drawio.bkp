        <mxCell id="8DqQCMdmOc6HaifYVGUy-4" parent="8DqQCMdmOc6HaifYVGUy-48" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;width=270;height=30;" value="mysqli_connect_error()" vertex="1">
