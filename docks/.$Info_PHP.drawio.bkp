        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-204" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;strokeColor=#33FF33;" value="&lt;div&gt;Wenn du willst, kann ich dir jetzt auch:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;ein UML‑Diagramm der Klassen machen&lt;/li&gt;&lt;li&gt;dir zeigen, wie du Updates/Deletes einbaust&lt;/li&gt;&lt;li&gt;dir helfen, das Ganze in ein MVC‑System zu überführen&lt;/li&gt;&lt;li&gt;oder dir erklären, wie du Fehlerbehandlung und Logging einbaust&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Sag einfach Bescheid, wohin du weitergehen möchtest.&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="620" x="-2180" y="3550" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-205" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🧱 1. Wenn die Klasse Datensätze lädt/speichert → Repository&lt;/div&gt;&lt;div&gt;Das ist der Standardname in moderner OOP‑Architektur.&lt;/div&gt;&lt;div&gt;Beispiele:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;UserRepository&lt;/li&gt;&lt;li&gt;AdminRepository&lt;/li&gt;&lt;li&gt;ProductRepository&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Ein Repository:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;lädt Daten aus der Datenbank&lt;/li&gt;&lt;li&gt;speichert Daten in der Datenbank&lt;/li&gt;&lt;li&gt;bildet eine Tabelle oder ein Domain‑Objekt ab&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Wenn deine Klasse also sowas macht wie:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Admin einfügen&lt;/li&gt;&lt;li&gt;Testdaten einfügen&lt;/li&gt;&lt;li&gt;Datensätze aus daten.php einfügen&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;…dann ist Repository der sauberste Name.&lt;/div&gt;" vertex="1">
          <mxGeometry height="301" width="460" x="-1520" y="1209" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-206" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;strokeColor=#33FF33;" value="&lt;div&gt;Wenn du willst, kann ich dir:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;die perfekte Struktur für dein Projekt empfehlen&lt;/li&gt;&lt;li&gt;zeigen, wie man Repository + Seeder kombiniert&lt;/li&gt;&lt;li&gt;oder dir helfen, deine aktuelle Klasse sauber umzubenennen und aufzuteilen&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Sag einfach Bescheid, wie tief du gehen möchtest.&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="460" x="-1520" y="2800" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-207" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="" vertex="1">
