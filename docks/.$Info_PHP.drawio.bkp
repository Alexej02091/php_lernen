        <mxCell id="wGHetAYyMtZg8utDns9d-15" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="🧠 &lt;strong&gt;Was ist &lt;/strong&gt;&lt;code&gt;$pdo&lt;/code&gt;&lt;strong&gt; in deiner Database‑Klasse?&lt;/strong&gt;&lt;div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;private PDO $pdo;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Das bedeutet:&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;ul&gt;&lt;li&gt;&lt;b&gt;$pdo ist eine Variable vom Typ PDO&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;also ein Datenbank‑Objekt&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;das die Verbindung zu MySQL hält&lt;/b&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
