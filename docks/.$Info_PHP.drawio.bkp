        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-133" parent="JwBW0XjGU_Lk8adR58iQ-3" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;width=170;height=30;" value="✅ &lt;strong&gt;JSON statt Datenbank&lt;/strong&gt;" vertex="1">
          <mxGeometry height="2210" width="3090" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-134" parent="JwBW0XjGU_Lk8adR58iQ-3" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h1&gt;✅ &lt;strong&gt;JSON statt Datenbank – einfaches Beispiel (ohne Verschlüsselung)&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Angenommen, du hast eine Datei:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;fallback.json&lt;/code&gt;&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;json&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;{&lt;br&gt;    &quot;status&quot;: &quot;ok&quot;,&lt;br&gt;    &quot;timestamp&quot;: 1712500000,&lt;br&gt;    &quot;items&quot;: [1, 2, 3]&lt;br&gt;}&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Dann kannst du diese Datei in PHP so laden:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;$json = file_get_contents(&quot;fallback.json&quot;);  // Datei einlesen&lt;br&gt;$data = json_decode($json, true);           // JSON → Array&lt;br&gt;&lt;br&gt;print_r($data);&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;h3&gt;Ergebnis:&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;Array&lt;br&gt;(&lt;br&gt;    [status] =&amp;gt; ok&lt;br&gt;    [timestamp] =&amp;gt; 1712500000&lt;br&gt;    [items] =&amp;gt; Array&lt;br&gt;        (&lt;br&gt;            [0] =&amp;gt; 1&lt;br&gt;            [1] =&amp;gt; 2&lt;br&gt;            [2] =&amp;gt; 3&lt;br&gt;        )&lt;br&gt;)&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🧩 &lt;strong&gt;Wie du es wie eine DB‑Abfrage nutzt&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Stell dir vor, du würdest sonst so etwas machen:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;$result = $db-&amp;gt;query(&quot;SELECT * FROM items&quot;);&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Jetzt machst du stattdessen:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;$data = json_decode(file_get_contents(&quot;fallback.json&quot;), true);&lt;br&gt;&lt;br&gt;$items = $data[&quot;items&quot;];   // wie DB-Daten&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;📌 &lt;strong&gt;Komplettes Beispiel: Fallback nutzen, wenn DB nicht erreichbar ist&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;try {&lt;br&gt;    // Versuch: Datenbank&lt;br&gt;    $items = $db-&amp;gt;query(&quot;SELECT * FROM items&quot;)-&amp;gt;fetchAll();&lt;br&gt;} catch (Exception $e) {&lt;br&gt;    // Fallback: JSON-Datei&lt;br&gt;    $json = file_get_contents(&quot;fallback.json&quot;);&lt;br&gt;    $data = json_decode($json, true);&lt;br&gt;    $items = $data[&quot;items&quot;];&lt;br&gt;}&lt;br&gt;&lt;br&gt;print_r($items);&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;So funktioniert ein echter Fallback‑Mechanismus.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎯 &lt;strong&gt;Zusammenfassung&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ohne Verschlüsselung brauchst du nur:&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;&lt;strong&gt;1. Datei lesen&lt;/strong&gt;&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;$json = file_get_contents(&quot;fallback.json&quot;);&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;h3&gt;&lt;strong&gt;2. JSON in Array umwandeln&lt;/strong&gt;&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;$data = json_decode($json, true);&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;h3&gt;&lt;strong&gt;3. Daten verwenden&lt;/strong&gt;&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;$items = $data[&quot;items&quot;];&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div data-testid=&quot;chat-page&quot;&gt;&lt;/div&gt;&lt;div class=&quot;pointer-events-none absolute bottom-0 w-full&quot;&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="1430" width="960" x="40" y="40" as="geometry" />
        </mxCell>
