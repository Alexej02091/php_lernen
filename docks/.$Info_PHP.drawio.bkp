          <mxGeometry height="320" width="610" as="geometry" />
        </mxCell>
        <mxCell id="pKHLCEEhMPk__EJ80ix6-2" parent="pKHLCEEhMPk__EJ80ix6-15" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="🧩 &lt;strong&gt;Wie läuft das technisch ab?&lt;/strong&gt;" vertex="1">
          <mxGeometry height="30" width="200" x="40" y="70" as="geometry" />
        </mxCell>
        <mxCell id="pKHLCEEhMPk__EJ80ix6-4" parent="pKHLCEEhMPk__EJ80ix6-15" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;1️⃣ Frontend sendet Request&lt;/div&gt;&lt;div&gt;Beispiel in React:&lt;/div&gt;&lt;div&gt;&lt;div&gt;axios.post(&quot;/api/login&quot;, { email, password })&lt;/div&gt;&lt;div&gt;&amp;nbsp; .then(res =&amp;gt; console.log(res.data));&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="240" x="310" y="10" as="geometry" />
        </mxCell>
        <mxCell id="pKHLCEEhMPk__EJ80ix6-5" parent="pKHLCEEhMPk__EJ80ix6-15" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;2️⃣ Backend empfängt Request und verarbeitet ihn&lt;/div&gt;&lt;div&gt;z. B. in deinem AuthController.&lt;/div&gt;" vertex="1">
          <mxGeometry height="40" width="290" x="310" y="100" as="geometry" />
        </mxCell>
        <mxCell id="pKHLCEEhMPk__EJ80ix6-7" parent="pKHLCEEhMPk__EJ80ix6-15" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;3️⃣ Backend setzt Header → bevor es etwas ausgibt&lt;/div&gt;&lt;div&gt;Beispiel:&lt;/div&gt;&lt;div&gt;&lt;div&gt;header(&quot;Content-Type: application/json&quot;);&lt;/div&gt;&lt;div&gt;echo json_encode([&quot;status&quot; =&amp;gt; &quot;ok&quot;]);&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="290" x="310" y="155" as="geometry" />
        </mxCell>
        <mxCell id="pKHLCEEhMPk__EJ80ix6-8" parent="pKHLCEEhMPk__EJ80ix6-15" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;4️⃣ Frontend empfängt die Antwort + Header&lt;/div&gt;&lt;div&gt;Axios zeigt dir:&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;res.headers&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;res.data&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="280" x="310" y="240" as="geometry" />
        </mxCell>
        <mxCell id="pKHLCEEhMPk__EJ80ix6-9" parent="pKHLCEEhMPk__EJ80ix6-15" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="🧠 Wichtig: Du setzt Header nicht „weil Frontend existiert“, sondern weil du die Antwort definierst&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Das Backend muss dem Browser sagen:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;„Diese Antwort ist JSON“&lt;/li&gt;&lt;li&gt;„Diese Antwort ist ein Redirect“&lt;/li&gt;&lt;li&gt;„Diese Antwort ist ein Download“&lt;/li&gt;&lt;li&gt;„Diese Antwort darf nicht gecached werden“&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Das passiert immer vor dem eigentlichen Inhalt.&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="290" x="10" y="140" as="geometry" />
