        <mxCell id="qO_WYtTIfSz8GS38qmcU-53" parent="qO_WYtTIfSz8GS38qmcU-78" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;strokeColor=#00CC00;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du willst, kann ich dir:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;eine &lt;strong&gt;komplette Fallback‑Manager‑Klasse&lt;/strong&gt; bauen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;eine Version mit &lt;strong&gt;Passwort statt Key&lt;/strong&gt; (PBKDF2)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;eine &lt;strong&gt;automatische Speicherung + Laden&lt;/strong&gt; der verschlüsselten JSON‑Datei&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;oder das Ganze in dein Projekt integrieren&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag mir einfach, wie du es am liebsten hättest.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="190" width="650" x="30" y="1550" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-59" connectable="0" parent="qO_WYtTIfSz8GS38qmcU-78" style="group" value="" vertex="1">
          <mxGeometry height="1090" width="340" x="2380" y="580" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-54" parent="qO_WYtTIfSz8GS38qmcU-59" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h2&gt;🔍 &lt;strong&gt;Was macht &lt;/strong&gt;&lt;code&gt;json_encode()&lt;/code&gt;&lt;strong&gt;?&lt;/strong&gt;&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Es nimmt ein PHP‑Array oder Objekt&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;und wandelt es in einen &lt;strong&gt;JSON‑String&lt;/strong&gt; um&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;JSON ist einfach Text, den du speichern, verschlüsseln oder übertragen kannst&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Beispiel:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;$data = [&quot;name&quot; =&amp;gt; &quot;Max&quot;, &quot;age&quot; =&amp;gt; 30];&lt;br/&gt;&lt;br/&gt;$json = json_encode($data);&lt;br/&gt;&lt;br/&gt;echo $json;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ausgabe:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;{&quot;name&quot;:&quot;Max&quot;,&quot;age&quot;:30}&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="370" width="320" x="10" y="40" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-55" parent="qO_WYtTIfSz8GS38qmcU-59" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;width=150;height=30;" value="json_encode()" vertex="1">
          <mxGeometry height="1090" width="340" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-56" parent="qO_WYtTIfSz8GS38qmcU-59" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h2&gt;✔️ &lt;code&gt;json_encode()&lt;/code&gt; ist Teil von PHP selbst&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du brauchst:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;keine Library&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;kein Composer&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;keine Erweiterung&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Es funktioniert in &lt;strong&gt;jedem normalen PHP‑Setup&lt;/strong&gt;.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du willst, zeige ich dir auch:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;wie du JSON &lt;strong&gt;validierst&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;wie du JSON &lt;strong&gt;komprimierst&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;wie du JSON &lt;strong&gt;verschlüsselst und speicherst&lt;/strong&gt; (kompletter Fallback‑Flow)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag einfach Bescheid.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="360" width="320" x="10" y="720" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-57" parent="qO_WYtTIfSz8GS38qmcU-59" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h2&gt;🧩 Nützliche Optionen&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du kannst &lt;code&gt;json_encode()&lt;/code&gt; auch schöner formatieren:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;$json = json_encode($data, JSON_PRETTY_PRINT);&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Dann sieht es so aus:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;{&lt;br/&gt;    &quot;name&quot;: &quot;Max&quot;,&lt;br/&gt;    &quot;age&quot;: 30&lt;br/&gt;}&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="260" width="320" x="10" y="430" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-77" connectable="0" parent="qO_WYtTIfSz8GS38qmcU-78" style="group" value="" vertex="1">
          <mxGeometry height="2270" width="1600" x="740" y="650" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-61" parent="qO_WYtTIfSz8GS38qmcU-77" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;width=330;height=30;" value="openssl_encrypt()" vertex="1">
          <mxGeometry height="2270" width="1600" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-62" parent="qO_WYtTIfSz8GS38qmcU-77" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;openssl_encrypt()&lt;/code&gt; ist eine &lt;strong&gt;eingebaute PHP‑Funktion&lt;/strong&gt;, die Daten mit einem bestimmten Verschlüsselungs‑Algorithmus verschlüsselt — zum Beispiel &lt;strong&gt;AES‑256‑GCM&lt;/strong&gt; oder &lt;strong&gt;AES‑256‑CBC&lt;/strong&gt;.&lt;br/&gt;Sie ist Teil der OpenSSL‑Extension, die in fast allen PHP‑Installationen standardmäßig aktiv ist.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ich erkläre dir klar und verständlich, was sie genau macht.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="150" width="330" x="30" y="50" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-63" parent="qO_WYtTIfSz8GS38qmcU-77" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h1&gt;🔐 &lt;strong&gt;Was macht &lt;/strong&gt;&lt;code&gt;openssl_encrypt()&lt;/code&gt;&lt;strong&gt;?&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Kurz gesagt:&lt;/span&gt;&lt;/p&gt;&lt;blockquote&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;openssl_encrypt()&lt;/code&gt;&lt;strong&gt; nimmt einen Text (z. B. JSON) und wandelt ihn in verschlüsselten, unlesbaren Datenmüll um.&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/blockquote&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Nur wer den richtigen &lt;strong&gt;Schlüssel&lt;/strong&gt; und ggf. &lt;strong&gt;IV&lt;/strong&gt; und &lt;strong&gt;Tag&lt;/strong&gt; hat, kann die Daten wieder entschlüsseln.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="220" width="340" x="31" y="220" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-64" parent="qO_WYtTIfSz8GS38qmcU-77" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h1&gt;🧩 &lt;strong&gt;Was passiert technisch?&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;openssl_encrypt()&lt;/code&gt;:&lt;/span&gt;&lt;/p&gt;&lt;ol start=&quot;1&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;nimmt deinen Klartext (z. B. JSON‑String)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;nimmt deinen Verschlüsselungs‑Algorithmus (z. B. &lt;code&gt;aes-256-gcm&lt;/code&gt;)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;nimmt deinen geheimen Schlüssel&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;nimmt einen IV (Initialisierungsvektor)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;erzeugt daraus &lt;strong&gt;Ciphertext&lt;/strong&gt; (verschlüsselte Daten)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;gibt optional einen &lt;strong&gt;Auth‑Tag&lt;/strong&gt; zurück (bei GCM)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Der Rückgabewert ist ein &lt;strong&gt;binärer String&lt;/strong&gt;, den du meist Base64‑kodierst, um ihn speichern zu können.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="330" width="341" x="30" y="450" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-65" parent="qO_WYtTIfSz8GS38qmcU-77" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h1&gt;🛠️ &lt;strong&gt;Beispiel: AES‑256‑GCM&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;$encrypted = openssl_encrypt(&lt;br&gt;    $json,            // Klartext&lt;br&gt;    &quot;aes-256-gcm&quot;,    // Algorithmus&lt;br&gt;    $key,             // geheimer Schlüssel&lt;br&gt;    OPENSSL_RAW_DATA, // Ausgabe als Rohdaten&lt;br&gt;    $iv,              // Initialisierungsvektor&lt;br&gt;    $tag              // Authentifizierungs-Tag (wird gefüllt)&lt;br&gt;);&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="230" width="420" x="31" y="800" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-66" parent="qO_WYtTIfSz8GS38qmcU-77" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h1&gt;🎯 &lt;strong&gt;Zusammenfassung&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;openssl_encrypt()&lt;/code&gt;:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;ist &lt;strong&gt;eingebaut in PHP&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;verschlüsselt Text (z. B. JSON)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;unterstützt moderne Algorithmen wie &lt;strong&gt;AES‑256‑GCM&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;erzeugt Ciphertext, den du speichern kannst&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;benötigt Schlüssel + IV + (bei GCM) Tag&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du brauchst &lt;strong&gt;keine extra Datei&lt;/strong&gt;, &lt;strong&gt;keine Library&lt;/strong&gt;, &lt;strong&gt;keine Installation&lt;/strong&gt;.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="250" width="370" x="41" y="1610" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-67" parent="qO_WYtTIfSz8GS38qmcU-77" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h1&gt;🔒 &lt;strong&gt;Warum ist AES‑256‑GCM so gut?&lt;/strong&gt;&lt;/h1&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;sehr sicher&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;schnell&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;verhindert Manipulation (durch Auth‑Tag)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Standard in modernen APIs&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn jemand die Datei verändert, schlägt die Entschlüsselung sofort fehl.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="250" width="391" x="30" y="1330" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-68" parent="qO_WYtTIfSz8GS38qmcU-77" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h1&gt;📌 &lt;strong&gt;Parameter erklärt&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div tabindex=&quot;0&quot; role=&quot;group&quot; aria-label=&quot;Scrollbare Tabelle&quot;&gt;&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Parameter&lt;/th&gt;&lt;th&gt;Bedeutung&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;$data&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Der Klartext, den du verschlüsseln willst (z. B. JSON)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;$cipher_algo&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Algorithmus, z. B. &lt;code&gt;aes-256-gcm&lt;/code&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;$key&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Geheimer Schlüssel (z. B. 32 Bytes für AES‑256)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;$options&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Meist &lt;code&gt;OPENSSL_RAW_DATA&lt;/code&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;$iv&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Initialisierungsvektor (z. B. 12 Bytes bei GCM)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;&amp;amp;$tag&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Auth‑Tag (nur bei GCM)&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="400" x="31" y="1060" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-69" parent="qO_WYtTIfSz8GS38qmcU-77" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du willst, erkläre ich dir auch:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;wie &lt;code&gt;openssl_decrypt()&lt;/code&gt; funktioniert&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;wie du Schlüssel sicher speicherst&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;wie du eine komplette Fallback‑Klasse baust&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;oder wie du Passwort‑basierte Verschlüsselung machst (PBKDF2)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag einfach Bescheid.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="200" width="370" x="40.5" y="1880" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-72" parent="qO_WYtTIfSz8GS38qmcU-77" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ich gebe dir eine klare, verständliche Erklärung zu &lt;strong&gt;OPENSSL_RAW_DATA&lt;/strong&gt;, &lt;strong&gt;$cipher&lt;/strong&gt; und &lt;strong&gt;$iv&lt;/strong&gt;, damit du genau weißt, was in deinem Code passiert.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🔍 &lt;strong&gt;1. Was bedeutet &lt;/strong&gt;&lt;code&gt;OPENSSL_RAW_DATA&lt;/code&gt;&lt;strong&gt;?&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;OPENSSL_RAW_DATA&lt;/code&gt; ist eine &lt;strong&gt;Option&lt;/strong&gt;, die &lt;code&gt;openssl_encrypt()&lt;/code&gt; sagt:&lt;/span&gt;&lt;/p&gt;&lt;blockquote&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Gib mir die verschlüsselten Daten als &lt;/strong&gt;&lt;em&gt;&lt;strong&gt;Rohbytes&lt;/strong&gt;&lt;/em&gt;&lt;strong&gt; zurück, nicht als Base64‑String.&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/blockquote&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ohne diese Option würde PHP automatisch Base64‑kodieren.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Warum ist RAW besser?&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du hast &lt;strong&gt;volle Kontrolle&lt;/strong&gt; über die Ausgabe&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du kannst &lt;strong&gt;selbst entscheiden&lt;/strong&gt;, wann du Base64 nutzt&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Es ist &lt;strong&gt;sauberer&lt;/strong&gt;, wenn du Ciphertext, IV und Tag getrennt speicherst&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Beispiel:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div tabindex=&quot;0&quot; role=&quot;group&quot; aria-label=&quot;Scrollbare Tabelle&quot;&gt;&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Option&lt;/th&gt;&lt;th&gt;Ausgabe&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;mit &lt;/strong&gt;&lt;code&gt;OPENSSL_RAW_DATA&lt;/code&gt;&lt;/td&gt;&lt;td&gt;Binäre Rohdaten (nicht lesbar)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;ohne&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Base64‑String&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;h1&gt;🔐 &lt;strong&gt;2. Was ist &lt;/strong&gt;&lt;code&gt;$cipher&lt;/code&gt;&lt;strong&gt;?&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;$cipher&lt;/code&gt; ist der &lt;strong&gt;verschlüsselte Text&lt;/strong&gt; (Ciphertext).&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Also:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;$json&lt;/code&gt; = Klartext (lesbar)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;$cipher&lt;/code&gt; = verschlüsselte Version (nicht lesbar)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Beispiel:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;$cipher = openssl_encrypt(...);&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Der Inhalt sieht dann z. B. so aus (binär):&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;�x�~�}��Z�...&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Deshalb speichert man ihn meistens Base64‑kodiert:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;base64_encode($cipher);&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🔑 &lt;strong&gt;3. Was ist &lt;/strong&gt;&lt;code&gt;$iv&lt;/code&gt;&lt;strong&gt;? (Initialisierungsvektor)&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Der &lt;strong&gt;IV (Initialisierungsvektor)&lt;/strong&gt; ist ein zufälliger Wert, der:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;für jede Verschlüsselung neu erzeugt werden muss&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;nicht geheim ist&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;aber &lt;strong&gt;unbedingt gespeichert werden muss&lt;/strong&gt;, sonst kann man nicht entschlüsseln&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Warum wichtig?&lt;/span&gt;&lt;/p&gt;&lt;blockquote&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Der IV sorgt dafür, dass selbst bei gleichem Text und gleichem Schlüssel jedes Mal ein anderer Ciphertext entsteht.&lt;/span&gt;&lt;/p&gt;&lt;/blockquote&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Bei AES‑256‑GCM ist der IV &lt;strong&gt;12 Bytes lang&lt;/strong&gt;:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;$iv = random_bytes(12);&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🧩 &lt;strong&gt;Zusammengefasst&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div tabindex=&quot;0&quot; role=&quot;group&quot; aria-label=&quot;Scrollbare Tabelle&quot;&gt;&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Begriff&lt;/th&gt;&lt;th&gt;Bedeutung&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;OPENSSL_RAW_DATA&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Gib Rohdaten zurück (nicht Base64)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;$cipher&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Der verschlüsselte Text (Ciphertext)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;$iv&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Initialisierungsvektor, nötig zum Entschlüsseln&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;h1&gt;💡 Wenn du willst, kann ich dir auch erklären:&lt;/h1&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;was &lt;strong&gt;$tag&lt;/strong&gt; macht (Authentifizierungs‑Tag bei GCM)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;wie du alles in einer Datei speicherst&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;wie du eine komplette &lt;strong&gt;Encryptor‑Klasse&lt;/strong&gt; baust&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;wie du Passwort‑basierte Verschlüsselung machst (PBKDF2)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag einfach Bescheid, was du als Nächstes brauchst.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="1410" width="560" x="480" y="50" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-74" parent="qO_WYtTIfSz8GS38qmcU-77" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Der &lt;strong&gt;Tag&lt;/strong&gt; (Authentication Tag) ist ein extrem wichtiger Bestandteil von &lt;strong&gt;AES‑GCM&lt;/strong&gt;. Ohne ihn kann man die Daten &lt;strong&gt;nicht entschlüsseln&lt;/strong&gt;, und er schützt dich zusätzlich vor Manipulation.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ich erkläre dir das so klar wie möglich.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🔐 &lt;strong&gt;Was ist der Tag bei AES‑GCM?&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Der &lt;strong&gt;Tag&lt;/strong&gt; ist ein kurzer Datenblock (meist 16 Bytes), den AES‑GCM beim Verschlüsseln erzeugt.&lt;br&gt;Er dient als &lt;strong&gt;Integritäts‑ und Authentizitätsnachweis&lt;/strong&gt;.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;👉 &lt;strong&gt;Der Tag beweist, dass die verschlüsselten Daten unverändert und echt sind.&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn jemand auch nur &lt;strong&gt;1 Bit&lt;/strong&gt; in der Datei ändert, schlägt die Entschlüsselung sofort fehl.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🧩 &lt;strong&gt;Warum ist der Tag so wichtig?&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;AES‑GCM ist ein sogenannter &lt;strong&gt;AEAD‑Modus&lt;/strong&gt;:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;A&lt;/strong&gt;uthenticated&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;E&lt;/strong&gt;ncryption&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;A&lt;/strong&gt;ssociated&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;D&lt;/strong&gt;ata&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Das bedeutet:&lt;/span&gt;&lt;/p&gt;&lt;blockquote&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du bekommst Verschlüsselung &lt;strong&gt;und&lt;/strong&gt; Manipulationsschutz in einem.&lt;/span&gt;&lt;/p&gt;&lt;/blockquote&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Der Tag ist der Teil, der den Manipulationsschutz liefert.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🔍 &lt;strong&gt;Wie entsteht der Tag?&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Beim Verschlüsseln:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;$encrypted = openssl_encrypt(&lt;br&gt;    $json,&lt;br&gt;    &quot;aes-256-gcm&quot;,&lt;br&gt;    $key,&lt;br&gt;    OPENSSL_RAW_DATA,&lt;br&gt;    $iv,&lt;br&gt;    $tag   // ← wird hier automatisch gefüllt&lt;br&gt;);&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;PHP schreibt den Tag in die Variable &lt;code&gt;$tag&lt;/code&gt;.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🔓 &lt;strong&gt;Wie wird der Tag beim Entschlüsseln genutzt?&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Beim Entschlüsseln musst du den Tag wieder mitgeben:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;$decrypted = openssl_decrypt(&lt;br&gt;    $encrypted,&lt;br&gt;    &quot;aes-256-gcm&quot;,&lt;br&gt;    $key,&lt;br&gt;    OPENSSL_RAW_DATA,&lt;br&gt;    $iv,&lt;br&gt;    $tag   // ← ohne diesen Tag schlägt es fehl&lt;br&gt;);&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;der Schlüssel falsch ist&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;der IV falsch ist&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;der Ciphertext verändert wurde&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;der Tag nicht passt&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;→ &lt;strong&gt;Entschlüsselung schlägt fehl&lt;/strong&gt;.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;📌 &lt;strong&gt;Zusammenfassung&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div tabindex=&quot;0&quot; role=&quot;group&quot; aria-label=&quot;Scrollbare Tabelle&quot;&gt;&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Element&lt;/th&gt;&lt;th&gt;Bedeutung&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;Cipher&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Der verschlüsselte Text&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;IV&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Initialisierungsvektor (nicht geheim, aber wichtig)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;Tag&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Authentifizierungs‑Tag, schützt vor Manipulation&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;h1&gt;🎯 &lt;strong&gt;Merke dir:&lt;/strong&gt;&lt;/h1&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Ohne Tag → keine Entschlüsselung möglich&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Tag muss gespeichert werden&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Tag ist nicht geheim&lt;/strong&gt;, aber &lt;strong&gt;unverzichtbar&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;AES‑GCM ist sicherer als CBC&lt;/strong&gt;, weil es den Tag hat&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du willst, zeige ich dir:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;wie du Cipher + IV + Tag in &lt;strong&gt;einer Datei&lt;/strong&gt; speichern kannst&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;wie du eine &lt;strong&gt;komplette Encryptor‑Klasse&lt;/strong&gt; baust&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;wie du einen &lt;strong&gt;Fallback‑Manager&lt;/strong&gt; programmierst&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag einfach Bescheid, wie du weitermachen möchtest.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="1610" width="500" x="1080" y="50" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-76" parent="qO_WYtTIfSz8GS38qmcU-77" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Das ist eine gute Frage — und genau an dieser Stelle wird klar, &lt;strong&gt;wie du die verschlüsselten Daten später speichern und wieder entschlüsseln kannst&lt;/strong&gt;.&lt;br&gt;Ich erkläre dir &lt;strong&gt;jede Zeile&lt;/strong&gt; so, dass du sofort verstehst, was passiert.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🔍 &lt;strong&gt;Was macht dieser Code?&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;return [&lt;br&gt;    &quot;cipher&quot; =&amp;gt; base64_encode($cipher),&lt;br&gt;    &quot;iv&quot;     =&amp;gt; base64_encode($iv),&lt;br&gt;    &quot;tag&quot;    =&amp;gt; base64_encode($tag)&lt;br&gt;];&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Er gibt ein &lt;strong&gt;Array&lt;/strong&gt; zurück, das drei wichtige Werte enthält:&lt;/span&gt;&lt;/p&gt;&lt;ol start=&quot;1&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;cipher&lt;/strong&gt; → der verschlüsselte Text&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;iv&lt;/strong&gt; → der Initialisierungsvektor&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;tag&lt;/strong&gt; → der Authentifizierungs‑Tag&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alle drei werden &lt;strong&gt;Base64‑kodiert&lt;/strong&gt;, damit du sie problemlos speichern kannst.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🧩 &lt;strong&gt;Warum Base64?&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Weil &lt;code&gt;$cipher&lt;/code&gt;, &lt;code&gt;$iv&lt;/code&gt; und &lt;code&gt;$tag&lt;/code&gt; &lt;strong&gt;binäre Daten&lt;/strong&gt; sind.&lt;br&gt;Binäre Daten können:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sonderzeichen enthalten&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Nullbytes enthalten&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;beim Speichern kaputtgehen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;in JSON oder Dateien Probleme machen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Base64 macht daraus &lt;strong&gt;sauberen Text&lt;/strong&gt;, z. B.:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;QkFTRTY0RU5DT0RFRF9EQVRFTg==&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Damit kannst du sie:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;in Dateien speichern&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;in JSON speichern&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;in der Datenbank speichern&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;über APIs senden&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;" vertex="1">
