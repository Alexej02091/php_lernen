        <mxCell id="jShnli8X3TEjpVxSGF65-5" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=5;" value="&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;$app-&amp;gt;run();&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Jetzt wird die Anwendung &lt;/span&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;wirklich gestartet&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;.&lt;/span&gt;.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Typische Aufgaben einer run()‑Methode:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;HTTP‑Request analysieren&lt;/li&gt;&lt;li&gt;Router starten&lt;/li&gt;&lt;li&gt;Controller auswählen&lt;/li&gt;&lt;li&gt;Controller ausführen&lt;/li&gt;&lt;li&gt;Response erzeugen&lt;/li&gt;&lt;li&gt;Response an den Browser senden&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Kurz:&lt;/div&gt;&lt;div&gt;Hier passiert die eigentliche Logik deiner Web‑App.&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="310" x="490" y="-930" as="geometry" />
        </mxCell>
