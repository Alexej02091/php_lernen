          <mxGeometry height="20" width="400" y="20" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-171" parent="oGzVnZ6ClYmYdJZ-8DAw-170" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;fontSize=12;align=left;verticalAlign=top;spacingLeft=5;" value="Repository" vertex="1">
