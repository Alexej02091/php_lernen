        <mxCell id="wGHetAYyMtZg8utDns9d-18" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;Alexej, das ist eine der wichtigsten Zeilen in deinem ganzen Backend‑Bootstrap.&lt;/div&gt;&lt;div&gt;Wenn du diese verstehst, verstehst du, wie dein System automatisch die richtigen Module für die richtige Rolle lädt.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Ich erkläre dir das absolut klar und ohne Magie.&lt;/div&gt;" vertex="1">
