        <mxCell id="uHGIM_KOHQKdvXlXlwwf-6" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" value="&lt;b&gt;vendor/autoload.php&lt;/b&gt;&lt;div&gt;50 % von Composer und PSR‑4‑Autoloading.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;strong&gt;Es ist die Datei, die Composer automatisch erzeugt, um alle Klassen in deinem Projekt automatisch zu laden.&lt;/strong&gt;&lt;/div&gt;&lt;div&gt;&lt;strong&gt;&lt;br&gt;&lt;/strong&gt;&lt;/div&gt;&lt;div&gt;Du musst also nicht mehr:&lt;strong&gt;&lt;/strong&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;require &#39;User.php&#39;;&lt;/div&gt;&lt;div&gt;require &#39;Database.php&#39;;&lt;/div&gt;&lt;div&gt;require &#39;Router.php&#39;;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;Sondern Composer erledigt das für dich.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Wie entsteht &lt;code&gt;vendor/autoload.php&lt;/code&gt;?&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Diese Datei wird &lt;strong&gt;automatisch generiert&lt;/strong&gt;, wenn du Composer benutzt.&lt;/span&gt;&lt;/p&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sobald du in deinem Projekt:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;composer install&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;oder&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;composer update&lt;/b&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;ausführst, erstellt Composer:&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;vendor/&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;autoload.php&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;composer/&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; ...&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Der Ordner vendor/ enthält:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;externe Libraries (z. B. Symfony, Guzzle, Doctrine)&lt;/li&gt;&lt;li&gt;den Autoloader&lt;/li&gt;&lt;li&gt;Composer‑Metadaten&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Du selbst schreibst diese Datei nicht — Composer erzeugt sie.&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Warum braucht man das?&lt;/div&gt;&lt;div&gt;&lt;div&gt;Weil moderne PHP‑Projekte PSR‑4 Autoloading verwenden.&lt;/div&gt;&lt;div&gt;Das bedeutet:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Klassen werden automatisch anhand ihres Namespaces gefunden&lt;/li&gt;&lt;li&gt;du musst keine require‑Befehle mehr schreiben&lt;/li&gt;&lt;li&gt;dein Code bleibt sauber, modular und professionell&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Beispiel:&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;new App\Controller\UserController();&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Composer weiß dann:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Namespace App\Controller&lt;/li&gt;&lt;li&gt;liegt in src/Controller/&lt;/li&gt;&lt;li&gt;lade die Datei UserController.php&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="740" width="400" x="1675" y="2390" as="geometry" />
        </mxCell>
        <mxCell id="uHGIM_KOHQKdvXlXlwwf-7" edge="1" parent="1" source="uHGIM_KOHQKdvXlXlwwf-4" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.063;entryDx=0;entryDy=0;entryPerimeter=0;" target="uHGIM_KOHQKdvXlXlwwf-6" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="870" y="1000" as="sourcePoint" />
            <mxPoint x="920" y="950" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="KFwVIHRTOtqEWXRbHIaX-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;BEISPIEL&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;lt;?php&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;// autoload.php @generated by Composer&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;if (PHP_VERSION_ID &amp;lt; 50600) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; if (!headers_sent()) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; header(&#39;HTTP/1.1 500 Internal Server Error&#39;);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; $err = &#39;Composer 2.3.0 dropped support for autoloading on PHP &amp;lt;5.6 and you are running &#39;.PHP_VERSION.&#39;, please upgrade PHP or use Composer 2.2 LTS via &quot;composer self-update --2.2&quot;. Aborting.&#39;.PHP_EOL;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; if (!ini_get(&#39;display_errors&#39;)) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; if (PHP_SAPI === &#39;cli&#39; || PHP_SAPI === &#39;phpdbg&#39;) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; fwrite(STDERR, $err);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; } elseif (!headers_sent()) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; echo $err;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; throw new RuntimeException($err);&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;require_once __DIR__ . &#39;/composer/autoload_real.php&#39;;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;return ComposerAutoloaderInit9b1754abf5b400ca77cdfbab065803d1::getLoader();&lt;/div&gt;" vertex="1">
          <mxGeometry height="380" width="530" x="2030" y="1850" as="geometry" />
        </mxCell>
        <mxCell id="KFwVIHRTOtqEWXRbHIaX-2" edge="1" parent="1" source="uHGIM_KOHQKdvXlXlwwf-4" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=-0.007;entryY=0.039;entryDx=0;entryDy=0;entryPerimeter=0;" target="KFwVIHRTOtqEWXRbHIaX-1" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
