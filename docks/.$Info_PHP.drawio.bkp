        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-151" edge="1" parent="1" source="oGzVnZ6ClYmYdJZ-8DAw-86" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.503;entryDx=0;entryDy=0;entryPerimeter=0;" target="oGzVnZ6ClYmYdJZ-8DAw-149" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="2690" y="140" as="sourcePoint" />
            <mxPoint x="2740" y="90" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-154" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="549" width="830" y="-1169" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-152" parent="oGzVnZ6ClYmYdJZ-8DAw-154" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;width=200;height=29;" value="Merksätze" vertex="1">
          <mxGeometry height="549" width="830" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-153" parent="oGzVnZ6ClYmYdJZ-8DAw-154" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;strong&gt;Eine Klasse = eine Verantwortung&lt;/strong&gt;  &lt;br/&gt;(Single Responsibility Principle)" vertex="1">
          <mxGeometry height="40" width="210" x="20" y="49" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-161" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🧱 Deine Situation (kurz zusammengefasst)&lt;/div&gt;&lt;div&gt;Du hast:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;eine PDO‑Klasse (selbst gebaut) → kümmert sich um DB‑Verbindung&lt;/li&gt;&lt;li&gt;eine index.php, wo du einen Admin in die DB einfügen willst&lt;/li&gt;&lt;li&gt;eine admin.php, wo du Buttons hast, die Testdatensätze einfügen&lt;/li&gt;&lt;li&gt;eine daten.php, wo du alle Datensätze bereits definierst&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Und du fragst:&lt;/div&gt;&lt;div&gt;👉 Soll ich für diese Fälle eine Extra‑Klasse verwenden?&lt;/div&gt;&lt;div&gt;Die Antwort ist:&lt;/div&gt;&lt;div&gt;Ja — und zwar immer dann, wenn du Daten in die Datenbank schreibst oder daraus liest.&lt;/div&gt;&lt;div&gt;Aber lass mich dir erklären, warum und wie.&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="510" x="-2730" y="1209" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-196" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;komplettes, sauberes, modernes OOP‑Beispiel, das genau zu deiner Situation passt:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;DataManager‑Klasse (fügt Admins, Testdaten, usw. ein)&lt;/li&gt;&lt;li&gt;daten.php (enthält deine Datensätze)&lt;/li&gt;&lt;li&gt;index.php (fügt Admin ein)&lt;/li&gt;&lt;li&gt;admin.php (Buttons für Testdaten)&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Ich halte es kompakt, aber professionell strukturiert.&lt;/div&gt;" vertex="1">
          <mxGeometry height="131" width="620" x="-2180" y="1209" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-197" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🎯 Warum du eine Extra‑Klasse brauchst&lt;/div&gt;&lt;div&gt;Du willst nicht, dass:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;index.php SQL‑Logik enthält&lt;/li&gt;&lt;li&gt;admin.php SQL‑Logik enthält&lt;/li&gt;&lt;li&gt;daten.php SQL‑Logik enthält&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Warum?&lt;/div&gt;&lt;div&gt;Weil sonst dein Projekt schnell zu einem Spaghetti‑Haufen wird, den du später kaum noch anfassen willst.&lt;/div&gt;&lt;div&gt;Stattdessen brauchst du eine Schicht, die sich um Datensätze kümmert.&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="510" x="-2730" y="1430" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-198" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🧩 Welche Klasse übernimmt das?&lt;/div&gt;&lt;div&gt;Du hast zwei sinnvolle Optionen:&lt;/div&gt;&lt;div&gt;Option A: Eine „Repository“-Klasse pro Tabelle&lt;/div&gt;&lt;div&gt;Beispiel (nur vom Konzept her):&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;AdminRepository → kümmert sich um Admins&lt;/li&gt;&lt;li&gt;TestDataRepository → kümmert sich um Testdatensätze&lt;/li&gt;&lt;li&gt;UserRepository → kümmert sich um Benutzer&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Das ist die sauberste Lösung.&lt;/div&gt;" vertex="1">
          <mxGeometry height="151" width="510" x="-2730" y="1619" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-200" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;Option B: Eine einzige „DataLoader“ oder „DataManager“-Klasse&lt;/div&gt;&lt;div&gt;Diese Klasse:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;bekommt deine PDO‑Instanz&lt;/li&gt;&lt;li&gt;hat Methoden wie insertAdmin(), insertTestData(), insertAllFromDatenPhp()&lt;/li&gt;&lt;li&gt;kümmert sich um alle Inserts/Updates/Deletes&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Das ist einfacher, aber immer noch sauber.&lt;/div&gt;" vertex="1">
          <mxGeometry height="121" width="510" x="-2730" y="1800" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-201" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;daten.php&lt;/div&gt;&lt;div&gt;Nur noch:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Arrays oder Objekte mit deinen Datensätzen&lt;/li&gt;&lt;li&gt;Keine SQL‑Logik&lt;/li&gt;&lt;li&gt;Wird von DataManager eingelesen&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="101" width="510" x="-2730" y="2239" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-202" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🧠 Was passiert dann in deinen Dateien?&lt;/div&gt;&lt;div&gt;index.php&lt;/div&gt;&lt;div&gt;Nur noch:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Daten sammeln (z. B. Admin‑Name, Passwort)&lt;/li&gt;&lt;li&gt;DataManager aufrufen → insertAdmin()&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Keine SQL‑Logik.&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="510" x="-2730" y="1950" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-203" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;admin.php&lt;/div&gt;&lt;div&gt;Nur noch:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Buttons → Aktionen&lt;/li&gt;&lt;li&gt;DataManager aufrufen → insertTestData()&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Keine SQL‑Logik.&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="510" x="-2730" y="2100" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-155" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🧱 Warum eine Extra‑Klasse für „Datensätze laden“ sinnvoll ist&lt;/div&gt;&lt;div&gt;Wenn du eine PDO‑Klasse hast, dann ist das deine Datenbank‑Verbindungsschicht.&lt;/div&gt;&lt;div&gt;Sie sollte nur eine Aufgabe haben:&lt;/div&gt;&lt;div&gt;👉 Verbindung herstellen + Queries ausführen.&lt;/div&gt;&lt;div&gt;Wenn du jetzt „Datensätze automatisch laden“ willst, dann ist das eine andere Verantwortung.&lt;/div&gt;&lt;div&gt;Und in OOP gilt:&lt;/div&gt;&lt;div&gt;Eine Klasse = eine Verantwortung&amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;(Single Responsibility Principle)&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="510" x="-3280" y="1209" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-156" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🎯 Was bringt dir eine Extra‑Klasse?&lt;/div&gt;&lt;div&gt;1. Saubere Trennung von Logik&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;PDO‑Klasse: kümmert sich um DB‑Verbindung&lt;/li&gt;&lt;li&gt;Loader/Repository/Model‑Klasse: kümmert sich um Datensätze&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Das macht deinen Code stabiler und leichter zu testen.&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="510" x="-3280" y="1369" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-157" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;2. Wiederverwendbarkeit&lt;/div&gt;&lt;div&gt;Wenn du später:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;andere Tabellen laden willst&lt;/li&gt;&lt;li&gt;andere Datenstrukturen hast&lt;/li&gt;&lt;li&gt;oder die Logik ändern musst&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;…dann musst du nicht deine PDO‑Klasse anfassen.&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="510" x="-3280" y="1499" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-158" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;3. Bessere Wartbarkeit&lt;/div&gt;&lt;div&gt;Wenn alles in einer Klasse steckt, wird sie schnell fett und unübersichtlich.&lt;/div&gt;&lt;div&gt;Mit einer Extra‑Klasse bleibt dein Projekt modular.&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="510" x="-3280" y="1639" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-159" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;4. Du kannst Regeln/Validierung einbauen&lt;/div&gt;&lt;div&gt;Bevor ein Datensatz gespeichert wird, kannst du:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;prüfen&lt;/li&gt;&lt;li&gt;filtern&lt;/li&gt;&lt;li&gt;transformieren&lt;/li&gt;&lt;li&gt;bereinigen&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Das gehört nicht in die PDO‑Klasse, sondern in eine eigene Schicht.&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="510" x="-3280" y="1719" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-160" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;5. Du öffnest dir den Weg zu echten OOP‑Mustern&lt;/div&gt;&lt;div&gt;Mit einer Extra‑Klasse kannst du später leicht:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Repository Pattern&lt;/li&gt;&lt;li&gt;Data Mapper&lt;/li&gt;&lt;li&gt;Active Record&lt;/li&gt;&lt;li&gt;Service Layer&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;einführen, ohne alles umzubauen.&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="510" x="-3280" y="1880" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-164" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;strokeColor=#33FF33;" value="&lt;div&gt;Wenn du willst, kann ich dir helfen:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;die beste Struktur für dein Projekt zu wählen&lt;/li&gt;&lt;li&gt;Repository vs. Model vs. Service zu vergleichen&lt;/li&gt;&lt;li&gt;dir eine Architektur empfehlen, die zu deinem Stil passt&lt;/li&gt;&lt;li&gt;oder dir zeigen, wie man das Ganze modern und sauber aufbaut&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Sag einfach, in welche Richtung du gehen möchtest.&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="510" x="-3280" y="2360" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-184" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="300" width="510" x="-3280" y="2040" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-162" parent="oGzVnZ6ClYmYdJZ-8DAw-184" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🧠 Wie nennt man diese Extra‑Klasse?&lt;/div&gt;&lt;div&gt;Es gibt mehrere sinnvolle Varianten, je nach Stil:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Alle sind okay — wichtig ist nur die &lt;strong&gt;Trennung der Verantwortlichkeiten&lt;/strong&gt;.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="510" as="geometry" />
        </mxCell>
        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-165" parent="oGzVnZ6ClYmYdJZ-8DAw-184" style="shape=table;startSize=0;container=1;collapsible=0;childLayout=tableLayout;fontSize=16;" value="" vertex="1">
          <mxGeometry height="100" width="400" x="10" y="40" as="geometry" />
        </mxCell>
