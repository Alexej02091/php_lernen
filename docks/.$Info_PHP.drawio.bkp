        <mxCell id="oGzVnZ6ClYmYdJZ-8DAw-175" parent="oGzVnZ6ClYmYdJZ-8DAw-174" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;fontSize=12;align=left;verticalAlign=top;spacingLeft=5;" value="Model" vertex="1">
          <mxGeometry height="20" width="76" as="geometry">
