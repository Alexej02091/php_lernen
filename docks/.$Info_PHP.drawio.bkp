        <mxCell id="KFwVIHRTOtqEWXRbHIaX-28" parent="KFwVIHRTOtqEWXRbHIaX-51" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=17;" value="🧭 Wie alles zusammenhängt&lt;div&gt;Hier ist der typische Request‑Flow:&lt;/div&gt;&lt;div&gt;&lt;div&gt;Browser → Route → Controller → Service → Repository → Model → zurück&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
