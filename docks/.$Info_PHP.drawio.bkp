        <mxCell id="qO_WYtTIfSz8GS38qmcU-40" parent="1" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="" vertex="1">
          <mxGeometry height="60" width="120" x="770" y="6240" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-43" parent="1" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="" vertex="1">
          <mxGeometry height="60" width="120" x="960" y="6240" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-44" parent="1" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="" vertex="1">
          <mxGeometry height="60" width="120" x="1130" y="6240" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-47" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="3000" width="2480" x="-2560" y="-1000" as="geometry" />
        </mxCell>
        <mxCell id="Fycb0FYdAB0d85_xRj8R-10" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h2&gt;🔐 1. JSON verschlüsseln – Grundidee&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;JSON ist ein String. Du nimmst also:&lt;/span&gt;&lt;/p&gt;&lt;ol start=&quot;1&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;JSON erzeugen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;JSON in einen String umwandeln&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;String mit einem Algorithmus verschlüsseln&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Verschlüsselten Text speichern oder übertragen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Beim Entschlüsseln läuft es umgekehrt.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="210" width="570" x="30" y="60" as="geometry" />
        </mxCell>
        <mxCell id="Fycb0FYdAB0d85_xRj8R-11" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ja – &lt;strong&gt;für ein PHP‑Backend gibt es sehr klare und sichere Wege, JSON zu verschlüsseln&lt;/strong&gt;.&lt;br/&gt;Der Klassiker ist &lt;strong&gt;OpenSSL mit AES‑256‑CBC oder AES‑256‑GCM&lt;/strong&gt;. JSON ist nur Text, also perfekt geeignet.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ich zeige dir direkt, wie das in der Praxis aussieht.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="110" width="520" x="670" y="60" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-1" parent="qO_WYtTIfSz8GS38qmcU-47" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;width=180;height=30;" value="&amp;nbsp;JSON verschlüsseln Info" vertex="1">
          <mxGeometry height="3000" width="2480" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-2" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h2&gt;🛠️ 2. Beispiel in JavaScript (AES‑256)&lt;/h2&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;js&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import CryptoJS from &quot;crypto-js&quot;;&lt;br&gt;&lt;br&gt;const data = { name: &quot;Max&quot;, age: 30 };&lt;br&gt;const jsonString = JSON.stringify(data);&lt;br&gt;&lt;br&gt;// Verschlüsseln&lt;br&gt;const encrypted = CryptoJS.AES.encrypt(jsonString, &quot;geheimesPasswort&quot;).toString();&lt;br&gt;&lt;br&gt;// Entschlüsseln&lt;br&gt;const bytes = CryptoJS.AES.decrypt(encrypted, &quot;geheimesPasswort&quot;);&lt;br&gt;const decrypted = JSON.parse(bytes.toString(CryptoJS.enc.Utf8));&lt;br&gt;&lt;br&gt;console.log(encrypted);&lt;br&gt;console.log(decrypted);&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="310" width="560" x="40" y="290" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-3" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h2&gt;🧱 3. Beispiel in Python (Fernet / AES)&lt;/h2&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;python&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;from cryptography.fernet import Fernet&lt;br/&gt;import json&lt;br/&gt;&lt;br/&gt;key = Fernet.generate_key()&lt;br/&gt;cipher = Fernet(key)&lt;br/&gt;&lt;br/&gt;data = {&quot;name&quot;: &quot;Max&quot;, &quot;age&quot;: 30}&lt;br/&gt;json_string = json.dumps(data)&lt;br/&gt;&lt;br/&gt;encrypted = cipher.encrypt(json_string.encode())&lt;br/&gt;decrypted = json.loads(cipher.decrypt(encrypted).decode())&lt;br/&gt;&lt;br/&gt;print(encrypted)&lt;br/&gt;print(decrypted)&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="300" width="560" x="40" y="620" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-4" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h2&gt;🔒 4. Welche Verschlüsselung ist sinnvoll?&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;AES‑256&lt;/strong&gt; (symmetrisch) → sehr verbreitet, schnell, sicher&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;RSA&lt;/strong&gt; (asymmetrisch) → gut für Schlüsselaustausch&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Fernet&lt;/strong&gt; (Python) → einfach &amp;amp; sicher&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;JWE (JSON Web Encryption)&lt;/strong&gt; → Standard für Web‑APIs&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="160" width="550" x="40" y="940" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-5" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h2&gt;🧩 5. JSON Web Encryption (JWE)&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du im Web arbeitest (APIs, Tokens), ist &lt;strong&gt;JWE&lt;/strong&gt; der offizielle Standard.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ein JWE sieht z. B. so aus:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;eyJhbGciOiJSU0EtT0FFUCIsImVuYyI6IkEyNTZHQ00ifQ...&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Das ist ein verschlüsseltes JSON‑Objekt.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="190" width="540" x="40" y="1120" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-6" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;strokeColor=#00CC00;" value="&lt;h2&gt;Wenn du willst, zeige ich dir:&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;wie man &lt;strong&gt;JWE&lt;/strong&gt; konkret nutzt&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;wie man JSON &lt;strong&gt;signiert&lt;/strong&gt; statt verschlüsselt (JWS)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;wie man JSON in &lt;strong&gt;Datenbanken verschlüsselt speichert&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag mir einfach, in welcher Sprache oder Umgebung du arbeitest.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="190" width="540" x="40" y="1330" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-9" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h2&gt;🔐 JSON in PHP verschlüsseln (AES‑256‑CBC)&lt;/h2&gt;&lt;h3&gt;&lt;strong&gt;Beispiel: Verschlüsseln&lt;/strong&gt;&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;$data = [&quot;name&quot; =&amp;gt; &quot;Max&quot;, &quot;age&quot; =&amp;gt; 30];&lt;br&gt;$json = json_encode($data);&lt;br&gt;&lt;br&gt;$key = openssl_random_pseudo_bytes(32); // 256-bit key&lt;br&gt;$iv  = openssl_random_pseudo_bytes(16); // 128-bit IV&lt;br&gt;&lt;br&gt;$encrypted = openssl_encrypt($json, &quot;AES-256-CBC&quot;, $key, 0, $iv);&lt;br&gt;&lt;br&gt;echo base64_encode($encrypted);&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="260" width="520" x="670" y="180" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-10" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h3&gt;&lt;strong&gt;Beispiel: Entschlüsseln&lt;/strong&gt;&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;$encryptedData = base64_decode($encrypted);&lt;br/&gt;&lt;br/&gt;$decrypted = openssl_decrypt($encryptedData, &quot;AES-256-CBC&quot;, $key, 0, $iv);&lt;br/&gt;&lt;br/&gt;$array = json_decode($decrypted, true);&lt;br/&gt;&lt;br/&gt;print_r($array);&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="190" width="520" x="670" y="450" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-11" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h2&gt;🧩 Was du dafür brauchst&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;OpenSSL&lt;/strong&gt; (in PHP standardmäßig aktiviert)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Einen &lt;strong&gt;256‑Bit Schlüssel&lt;/strong&gt; (32 Bytes)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Einen &lt;strong&gt;IV&lt;/strong&gt; (Initialisierungsvektor, 16 Bytes)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="130" width="520" x="670" y="660" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-12" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h2&gt;🔒 Noch sicherer: AES‑256‑GCM (mit Authentifizierung)&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;AES‑GCM verhindert Manipulationen, weil es einen Auth‑Tag erzeugt.&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;&lt;strong&gt;Verschlüsseln (GCM)&lt;/strong&gt;&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;$data = [&quot;role&quot; =&amp;gt; &quot;admin&quot;, &quot;id&quot; =&amp;gt; 42];&lt;br&gt;$json = json_encode($data);&lt;br&gt;&lt;br&gt;$key = openssl_random_pseudo_bytes(32);&lt;br&gt;$iv  = openssl_random_pseudo_bytes(12); // GCM nutzt 96-bit IV&lt;br&gt;&lt;br&gt;$tag = null;&lt;br&gt;&lt;br&gt;$encrypted = openssl_encrypt(&lt;br&gt;    $json,&lt;br&gt;    &quot;aes-256-gcm&quot;,&lt;br&gt;    $key,&lt;br&gt;    OPENSSL_RAW_DATA,&lt;br&gt;    $iv,&lt;br&gt;    $tag&lt;br&gt;);&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="390" width="520" x="670" y="810" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-13" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Hier kommt die &lt;strong&gt;sichere AES‑256‑GCM‑Variante&lt;/strong&gt;, perfekt geeignet für deinen Fallback‑Mechanismus.&lt;br/&gt;AES‑GCM ist moderner als CBC, weil es &lt;strong&gt;zusätzlich einen Auth‑Tag erzeugt&lt;/strong&gt;, der Manipulationen verhindert. Wenn jemand die Datei verändert, schlägt die Entschlüsselung sofort fehl.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ich zeige dir &lt;strong&gt;komplett lauffähige Beispiele&lt;/strong&gt; für:&lt;/span&gt;&lt;/p&gt;&lt;ol start=&quot;1&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;JSON → verschlüsseln → Datei speichern&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Datei → entschlüsseln → JSON zurückbekommen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="150" width="550" x="1870" y="60" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-14" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h3&gt;&lt;strong&gt;Entschlüsseln (GCM)&lt;/strong&gt;&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;$decrypted = openssl_decrypt(&lt;br&gt;    $encrypted,&lt;br&gt;    &quot;aes-256-gcm&quot;,&lt;br&gt;    $key,&lt;br&gt;    OPENSSL_RAW_DATA,&lt;br&gt;    $iv,&lt;br&gt;    $tag&lt;br&gt;);&lt;br&gt;&lt;br&gt;$array = json_decode($decrypted, true);&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="230" width="530" x="670" y="1220" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-16" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h2&gt;🧱 Alternative: JSON Web Encryption (JWE)&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du ein API‑Backend baust, ist &lt;strong&gt;JWE&lt;/strong&gt; der offizielle Standard.&lt;br/&gt;Es gibt fertige PHP‑Libraries:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;web-token/jwt-framework&lt;/code&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;firebase/php-jwt&lt;/code&gt; (für Signaturen, nicht Verschlüsselung)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Damit kannst du JSON‑Objekte als verschlüsselte Tokens übertragen.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="190" width="530" x="670" y="1470" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-17" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;strokeColor=#00CC00;" value="&lt;div data-testid=&quot;chat-page&quot;&gt;🔧 Wenn du mir sagst, wie dein Fallback genau funktionieren soll, kann ich dir:&lt;/div&gt;&lt;div data-testid=&quot;chat-page&quot;&gt;&lt;ul&gt;&lt;li&gt;eine komplette Utility‑Klasse schreiben&lt;/li&gt;&lt;li&gt;automatische Schlüsselrotation einbauen&lt;/li&gt;&lt;li&gt;Fallback‑Laden mit Fehlerbehandlung erstellen&lt;/li&gt;&lt;li&gt;oder das Ganze in dein Framework (Laravel, Symfony, Slim) einpassen&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div data-testid=&quot;chat-page&quot;&gt;Wie soll dein Fallback später genutzt werden — Konfiguration, Cache, Userdaten oder etwas anderes?&lt;/div&gt;&lt;div data-testid=&quot;chat-page&quot;&gt;&lt;/div&gt;&lt;div class=&quot;pointer-events-none absolute bottom-0 w-full&quot;&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div data-testid=&quot;chat-page&quot;&gt;&lt;/div&gt;&lt;div class=&quot;pointer-events-none absolute bottom-0 w-full&quot;&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="520" x="1270" y="1540" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-18" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;strokeColor=#00CC00;" value="&lt;h2&gt;Wenn du willst, kann ich dir auch zeigen:&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;wie man &lt;strong&gt;Schlüssel sicher speichert&lt;/strong&gt; (ENV, Key‑Vault, kein Git)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;wie man &lt;strong&gt;verschlüsselte JSON‑Felder in MySQL/PostgreSQL&lt;/strong&gt; speichert&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;wie man &lt;strong&gt;JWE&lt;/strong&gt; in PHP implementiert&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;wie man &lt;strong&gt;Passwort‑basierte Verschlüsselung (PBKDF2)&lt;/strong&gt; nutzt&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag mir einfach, was du genau vorhast – API, Login‑System, Datenbank‑Speicherung oder etwas anderes.&lt;/span&gt;&lt;/p&gt;&lt;div data-testid=&quot;chat-page&quot;&gt;&lt;/div&gt;&lt;div class=&quot;pointer-events-none absolute bottom-0 w-full&quot;&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="530" x="670" y="1680" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-19" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alles klar — wenn du &lt;strong&gt;eine JSON‑Datei als Fallback erzeugen und verschlüsseln&lt;/strong&gt; willst, ist das im PHP‑Backend absolut machbar. Ich zeige dir den kompletten Ablauf, wie man:&lt;/span&gt;&lt;/p&gt;&lt;ol start=&quot;1&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;ein Array → JSON macht&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;die JSON‑Daten verschlüsselt&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;die verschlüsselte Datei speichert&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;sie später wieder entschlüsselt und lädt&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Das ist ein sehr typisches Szenario für Offline‑Fallbacks, Caching oder Notfall‑Konfigurationen.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="190" width="520" x="1270" y="60" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-20" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h1&gt;🔐 &lt;strong&gt;1. JSON erzeugen und verschlüsseln (PHP)&lt;/strong&gt;&lt;/h1&gt;&lt;h3&gt;&lt;strong&gt;Beispiel: JSON → AES‑256‑CBC → Datei speichern&lt;/strong&gt;&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;$data = [&lt;br&gt;    &quot;status&quot; =&amp;gt; &quot;ok&quot;,&lt;br&gt;    &quot;timestamp&quot; =&amp;gt; time(),&lt;br&gt;    &quot;items&quot; =&amp;gt; [1, 2, 3]&lt;br&gt;];&lt;br&gt;&lt;br&gt;$json = json_encode($data, JSON_PRETTY_PRINT);&lt;br&gt;&lt;br&gt;// Schlüssel &amp;amp; IV (solltest du persistent speichern!)&lt;br&gt;$key = openssl_random_pseudo_bytes(32); // 256-bit&lt;br&gt;$iv  = openssl_random_pseudo_bytes(16); // 128-bit&lt;br&gt;&lt;br&gt;$encrypted = openssl_encrypt($json, &quot;AES-256-CBC&quot;, $key, 0, $iv);&lt;br&gt;&lt;br&gt;// Datei speichern&lt;br&gt;file_put_contents(&quot;fallback.json.enc&quot;, $encrypted);&lt;br&gt;&lt;br&gt;// Schlüssel separat speichern (z. B. .env)&lt;br&gt;file_put_contents(&quot;fallback.key&quot;, base64_encode($key));&lt;br&gt;file_put_contents(&quot;fallback.iv&quot;, base64_encode($iv));&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Damit hast du eine &lt;strong&gt;verschlüsselte Datei&lt;/strong&gt;, die niemand ohne Schlüssel lesen kann.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="490" width="520" x="1270" y="260" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-21" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h1&gt;🧩 &lt;strong&gt;Wichtige Hinweise&lt;/strong&gt;&lt;/h1&gt;&lt;h3&gt;&lt;strong&gt;Schlüssel niemals in Git speichern&lt;/strong&gt;&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Nutze &lt;code&gt;.env&lt;/code&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Oder ein Secret‑Manager (Azure Key Vault, AWS Secrets Manager, etc.)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;&lt;strong&gt;Warum AES‑256‑CBC?&lt;/strong&gt;&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Schnell&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Stabil&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;In PHP nativ unterstützt&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du Manipulationen verhindern willst, ist &lt;strong&gt;AES‑GCM&lt;/strong&gt; noch besser, weil es einen Auth‑Tag erzeugt.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="310" width="520" x="1270" y="1050" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-22" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h1&gt;🔓 &lt;strong&gt;2. Verschlüsselte JSON‑Datei wieder laden und entschlüsseln&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;$encrypted = file_get_contents(&quot;fallback.json.enc&quot;);&lt;br/&gt;&lt;br/&gt;$key = base64_decode(file_get_contents(&quot;fallback.key&quot;));&lt;br/&gt;$iv  = base64_decode(file_get_contents(&quot;fallback.iv&quot;));&lt;br/&gt;&lt;br/&gt;$decryptedJson = openssl_decrypt($encrypted, &quot;AES-256-CBC&quot;, $key, 0, $iv);&lt;br/&gt;&lt;br/&gt;$data = json_decode($decryptedJson, true);&lt;br/&gt;&lt;br/&gt;print_r($data);&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="280" width="520" x="1270" y="760" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-23" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h1&gt;💡 &lt;strong&gt;Optional: Noch sicherer mit AES‑256‑GCM&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du willst, kann ich dir auch eine Version mit GCM bauen — das ist moderner und verhindert, dass jemand die Datei unbemerkt verändert.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="140" width="520" x="1270" y="1380" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-27" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h2&gt;🧩 Was du dafür brauchst&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;OpenSSL&lt;/strong&gt; (in PHP standardmäßig aktiviert)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Einen &lt;strong&gt;256‑Bit Schlüssel&lt;/strong&gt; (32 Bytes)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Einen &lt;strong&gt;IV&lt;/strong&gt; (Initialisierungsvektor, 16 Bytes)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="130" width="520" x="670" y="870" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-29" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h2&gt;🔐 &lt;strong&gt;1. JSON verschlüsseln mit AES‑256‑GCM (PHP)&lt;/strong&gt;&lt;/h2&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;$data = [&lt;br&gt;    &quot;status&quot; =&amp;gt; &quot;ok&quot;,&lt;br&gt;    &quot;timestamp&quot; =&amp;gt; time(),&lt;br&gt;    &quot;items&quot; =&amp;gt; [1, 2, 3]&lt;br&gt;];&lt;br&gt;&lt;br&gt;$json = json_encode($data, JSON_PRETTY_PRINT);&lt;br&gt;&lt;br&gt;// Schlüssel &amp;amp; IV erzeugen&lt;br&gt;$key = random_bytes(32);   // 256-bit key&lt;br&gt;$iv  = random_bytes(12);   // 96-bit IV (Standard für GCM)&lt;br&gt;&lt;br&gt;$tag = null;&lt;br&gt;&lt;br&gt;// Verschlüsseln&lt;br&gt;$encrypted = openssl_encrypt(&lt;br&gt;    $json,&lt;br&gt;    &quot;aes-256-gcm&quot;,&lt;br&gt;    $key,&lt;br&gt;    OPENSSL_RAW_DATA,&lt;br&gt;    $iv,&lt;br&gt;    $tag&lt;br&gt;);&lt;br&gt;&lt;br&gt;// Datei speichern (Ciphertext + Tag + IV)&lt;br&gt;file_put_contents(&quot;fallback.json.enc&quot;, base64_encode($encrypted));&lt;br&gt;file_put_contents(&quot;fallback.tag&quot;, base64_encode($tag));&lt;br&gt;file_put_contents(&quot;fallback.iv&quot;, base64_encode($iv));&lt;br&gt;&lt;br&gt;// Schlüssel separat speichern (z. B. .env)&lt;br&gt;file_put_contents(&quot;fallback.key&quot;, base64_encode($key));&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="550" width="550" x="1870" y="230" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-30" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h2&gt;🧩 &lt;strong&gt;Warum AES‑GCM besser ist&lt;/strong&gt;&lt;/h2&gt;&lt;div&gt;&lt;div&gt;&lt;div tabindex=&quot;0&quot; role=&quot;group&quot; aria-label=&quot;Scrollbare Tabelle&quot;&gt;&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Feature&lt;/th&gt;&lt;th&gt;CBC&lt;/th&gt;&lt;th&gt;GCM&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;Verschlüsselung&lt;/td&gt;&lt;td&gt;✔️&lt;/td&gt;&lt;td&gt;✔️&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Integritätsschutz&lt;/td&gt;&lt;td&gt;❌&lt;/td&gt;&lt;td&gt;✔️ (Auth‑Tag)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Manipulation erkennbar&lt;/td&gt;&lt;td&gt;❌&lt;/td&gt;&lt;td&gt;✔️&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Geschwindigkeit&lt;/td&gt;&lt;td&gt;gut&lt;/td&gt;&lt;td&gt;sehr gut&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Moderne Empfehlung&lt;/td&gt;&lt;td&gt;mittel&lt;/td&gt;&lt;td&gt;hoch&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;GCM ist heute Standard in APIs, Cloud‑Systemen und modernen Backends.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="215" width="550" x="1870" y="1175" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-33" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h2&gt;🔓 &lt;strong&gt;2. JSON wieder entschlüsseln&lt;/strong&gt;&lt;/h2&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;$encrypted = base64_decode(file_get_contents(&quot;fallback.json.enc&quot;));&lt;br&gt;$tag       = base64_decode(file_get_contents(&quot;fallback.tag&quot;));&lt;br&gt;$iv        = base64_decode(file_get_contents(&quot;fallback.iv&quot;));&lt;br&gt;$key       = base64_decode(file_get_contents(&quot;fallback.key&quot;));&lt;br&gt;&lt;br&gt;$decryptedJson = openssl_decrypt(&lt;br&gt;    $encrypted,&lt;br&gt;    &quot;aes-256-gcm&quot;,&lt;br&gt;    $key,&lt;br&gt;    OPENSSL_RAW_DATA,&lt;br&gt;    $iv,&lt;br&gt;    $tag&lt;br&gt;);&lt;br&gt;&lt;br&gt;$data = json_decode($decryptedJson, true);&lt;br&gt;&lt;br&gt;print_r($data);&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="340" width="550" x="1870" y="810" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-34" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h2&gt;🛡️ &lt;strong&gt;Wichtige Hinweise&lt;/strong&gt;&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Schlüssel niemals in Git speichern&lt;/strong&gt;  &lt;br/&gt;→ in &lt;code&gt;.env&lt;/code&gt;, Secret‑Manager oder Server‑Config&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;IV muss pro Datei neu erzeugt werden&lt;/strong&gt;, aber darf öffentlich sein&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Tag muss gespeichert werden&lt;/strong&gt;, sonst ist Entschlüsselung unmöglich&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Base64‑Encoding&lt;/strong&gt; ist wichtig, damit Dateien sauber gespeichert werden können&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="190" width="550" x="1870" y="1430" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-35" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;strokeColor=#00CC00;" value="&lt;div data-testid=&quot;chat-page&quot;&gt;Willst du es noch komfortabler?&lt;/div&gt;&lt;div data-testid=&quot;chat-page&quot;&gt;Ich kann dir auf Wunsch:&lt;/div&gt;&lt;div data-testid=&quot;chat-page&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div data-testid=&quot;chat-page&quot;&gt;eine komplette PHP‑Klasse schreiben (JsonEncryptor.php)&lt;/div&gt;&lt;div data-testid=&quot;chat-page&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div data-testid=&quot;chat-page&quot;&gt;automatisches Fallback‑Laden mit Fehlerbehandlung&lt;/div&gt;&lt;div data-testid=&quot;chat-page&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div data-testid=&quot;chat-page&quot;&gt;eine Version mit Passwort statt Key (PBKDF2)&lt;/div&gt;&lt;div data-testid=&quot;chat-page&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div data-testid=&quot;chat-page&quot;&gt;Integration in Laravel, Symfony oder reines PHP&lt;/div&gt;&lt;div data-testid=&quot;chat-page&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div data-testid=&quot;chat-page&quot;&gt;Sag mir einfach, wie du es einsetzen möchtest.&lt;/div&gt;&lt;div data-testid=&quot;chat-page&quot;&gt;&lt;/div&gt;&lt;div class=&quot;pointer-events-none absolute bottom-0 w-full&quot;&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div data-testid=&quot;chat-page&quot;&gt;&lt;/div&gt;&lt;div class=&quot;pointer-events-none absolute bottom-0 w-full&quot;&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="190" width="540" x="1880" y="1690" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-36" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Kurz gesagt: &lt;strong&gt;Nein, du musst nichts extra herunterladen&lt;/strong&gt;, um JSON mit AES‑256‑GCM in PHP zu verschlüsseln.&lt;br/&gt;Alles, was du brauchst, ist &lt;strong&gt;bereits in PHP eingebaut&lt;/strong&gt;, solange die OpenSSL‑Extension aktiviert ist – und das ist bei fast allen PHP‑Installationen standardmäßig der Fall.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="560" x="1880" y="1930" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-37" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h2&gt;🔍 Was du brauchst (und schon hast)&lt;/h2&gt;&lt;h3&gt;✔️ &lt;strong&gt;OpenSSL in PHP&lt;/strong&gt;&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ist in &lt;strong&gt;XAMPP&lt;/strong&gt;, &lt;strong&gt;Laragon&lt;/strong&gt;, &lt;strong&gt;MAMP&lt;/strong&gt;, &lt;strong&gt;Docker‑PHP&lt;/strong&gt;, &lt;strong&gt;Ubuntu‑PHP&lt;/strong&gt;, &lt;strong&gt;Debian‑PHP&lt;/strong&gt;, &lt;strong&gt;Plesk&lt;/strong&gt;, &lt;strong&gt;cPanel&lt;/strong&gt; usw. standardmäßig aktiv&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du kannst prüfen, ob es aktiv ist:&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;php&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;phpinfo();&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du dort &lt;strong&gt;OpenSSL support: enabled&lt;/strong&gt; siehst, bist du startklar.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="240" width="560" x="1880" y="2040" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-38" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h2&gt;🧩 Was du &lt;em&gt;nicht&lt;/em&gt; brauchst&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Keine zusätzlichen Libraries&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Keine Composer‑Pakete&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Keine externen Tools&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Keine Downloads&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;AES‑GCM wird direkt von &lt;code&gt;openssl_encrypt()&lt;/code&gt; und &lt;code&gt;openssl_decrypt()&lt;/code&gt; unterstützt.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="200" width="560" x="1880" y="2310" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-39" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h2&gt;🔐 Wenn du AES‑256‑GCM nutzt, brauchst du nur:&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;openssl_encrypt()&lt;/code&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;openssl_decrypt()&lt;/code&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;random_bytes()&lt;/code&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alles davon ist &lt;strong&gt;in PHP integriert&lt;/strong&gt;.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="160" width="560" x="1880" y="2550" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-41" parent="qO_WYtTIfSz8GS38qmcU-47" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h2&gt;💡 Wann bräuchtest du etwas extra?&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Nur in diesen Spezialfällen:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du willst &lt;strong&gt;JWE (JSON Web Encryption)&lt;/strong&gt; → dann bräuchtest du eine Library wie &lt;code&gt;web-token/jwt-framework&lt;/code&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du willst &lt;strong&gt;Passwort‑basierte Verschlüsselung (PBKDF2)&lt;/strong&gt; → ist aber auch in PHP eingebaut (&lt;code&gt;hash_pbkdf2&lt;/code&gt;)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du willst &lt;strong&gt;asymmetrische RSA‑Verschlüsselung&lt;/strong&gt; → ebenfalls in PHP enthalten&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Für deinen Fallback‑Mechanismus reicht &lt;strong&gt;reines PHP + OpenSSL&lt;/strong&gt; völlig aus.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="220" width="550" x="1880" y="2740" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-28" edge="1" parent="qO_WYtTIfSz8GS38qmcU-47" source="qO_WYtTIfSz8GS38qmcU-11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="qO_WYtTIfSz8GS38qmcU-27" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-78" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="2970" width="2770" x="-4120" y="3070" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-49" parent="qO_WYtTIfSz8GS38qmcU-78" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;width=200;height=30;" value="JSON verschlüsselung" vertex="1">
          <mxGeometry height="2970" width="2770" as="geometry" />
        </mxCell>
        <mxCell id="qO_WYtTIfSz8GS38qmcU-50" parent="qO_WYtTIfSz8GS38qmcU-78" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;h1&gt;⭐ &lt;strong&gt;Variante 2: Mit eigener Klasse (empfohlen)&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Warum sinnvoll?&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;sauberer Code&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wiederverwendbarkeit&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;weniger Fehler&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;klarer Fallback‑Mechanismus&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Hier eine kompakte, professionelle Klasse:&lt;/span&gt;&lt;/p&gt;" vertex="1">
