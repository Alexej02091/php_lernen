        <mxCell id="Whp2AbG9F2wWwhStgsQD-5" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;fontSize=15;" value="public/index.php&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&amp;lt;?php&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;require __DIR__ . &#39;/../src/vendor/autoload.php&#39;;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;$app = new App\App();&lt;/div&gt;&lt;div&gt;$app-&amp;gt;boot();&lt;/div&gt;&lt;div&gt;$app-&amp;gt;run();&lt;/div&gt;&lt;/div&gt;" vertex="1">
