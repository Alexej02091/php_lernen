        <mxCell id="qO_WYtTIfSz8GS38qmcU-125" parent="tXCr_LoeB6MjJ_MeRAy6-19" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;width=190;height=40;" value="JSON erstellen" vertex="1">
          <mxGeometry height="4250" width="5590" as="geometry" />
        </mxCell>
        <mxCell id="JwBW0XjGU_Lk8adR58iQ-69" connectable="0" parent="tXCr_LoeB6MjJ_MeRAy6-19" style="group" value="" vertex="1">
          <mxGeometry height="880" width="920" x="3140" y="1560" as="geometry" />
        </mxCell>
        <mxCell id="JwBW0XjGU_Lk8adR58iQ-39" parent="JwBW0XjGU_Lk8adR58iQ-69" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;div&gt;1. Strukturelle Eigenschaften&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Name — eindeutige Bezeichnung der Spalte&lt;/li&gt;&lt;li&gt;Datentyp — z. B. INT, VARCHAR, DATE&lt;/li&gt;&lt;li&gt;Länge / Präzision — z. B. VARCHAR(100), DECIMAL(8,2)&lt;/li&gt;&lt;li&gt;Standardwert — voreingestellter Wert, wenn keiner angegeben wird&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="330" x="20" y="60" as="geometry" />
        </mxCell>
        <mxCell id="JwBW0XjGU_Lk8adR58iQ-41" parent="JwBW0XjGU_Lk8adR58iQ-69" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;width=390;height=40;" value="DB Info" vertex="1">
          <mxGeometry height="880" width="920" as="geometry" />
        </mxCell>
        <mxCell id="JwBW0XjGU_Lk8adR58iQ-42" parent="JwBW0XjGU_Lk8adR58iQ-69" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;div&gt;2. Integritäts- und Validierungsregeln&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;NOT NULL — Wert darf nicht fehlen&lt;/li&gt;&lt;li&gt;UNIQUE — jeder Wert muss einzigartig sein&lt;/li&gt;&lt;li&gt;CHECK‑Constraint — z. B. CHECK (Alter &amp;gt;= 0)&lt;/li&gt;&lt;li&gt;Primary Key — eindeutiger Identifikator&lt;/li&gt;&lt;li&gt;Foreign Key — verweist auf andere Tabelle&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="330" x="20" y="200" as="geometry" />
        </mxCell>
        <mxCell id="JwBW0XjGU_Lk8adR58iQ-43" parent="JwBW0XjGU_Lk8adR58iQ-69" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;div&gt;3. Automatisierungs- und Systemverhalten&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Auto‑Increment / Identity — automatische Nummerierung&lt;/li&gt;&lt;li&gt;Generated / Computed Column — Wert wird berechnet&lt;/li&gt;&lt;li&gt;On Update / On Delete Regeln — Verhalten bei Fremdschlüsselaktionen&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="330" x="20" y="330" as="geometry" />
        </mxCell>
        <mxCell id="JwBW0XjGU_Lk8adR58iQ-44" parent="JwBW0XjGU_Lk8adR58iQ-69" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;div&gt;4. Performance- und Speicherbezogene Eigenschaften&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Index — beschleunigt Abfragen&lt;/li&gt;&lt;li&gt;Collation — Sortierung/Zeichensatz für Text&lt;/li&gt;&lt;li&gt;Unsigned — nur positive Zahlen (z. B. MySQL)&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="330" x="20" y="470" as="geometry" />
        </mxCell>
        <mxCell id="JwBW0XjGU_Lk8adR58iQ-45" parent="JwBW0XjGU_Lk8adR58iQ-69" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;div&gt;5. Dokumentation&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Kommentar / Beschreibung — Zweck oder Bedeutung der Spalte&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="330" x="20" y="570" as="geometry" />
        </mxCell>
        <mxCell id="tXCr_LoeB6MjJ_MeRAy6-17" connectable="0" parent="tXCr_LoeB6MjJ_MeRAy6-19" style="group" value="" vertex="1">
          <mxGeometry height="2330" width="3040" x="45" y="1560" as="geometry" />
        </mxCell>
        <mxCell id="JwBW0XjGU_Lk8adR58iQ-66" parent="tXCr_LoeB6MjJ_MeRAy6-17" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;width=245;height=40;" value="OOP Info" vertex="1">
          <mxGeometry height="2330" width="3040" as="geometry" />
        </mxCell>
        <mxCell id="JwBW0XjGU_Lk8adR58iQ-67" parent="tXCr_LoeB6MjJ_MeRAy6-17" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;div&gt;🎯 Das ist eine „Assoziation“ – genauer: eine Verwendungsbeziehung (Usage / Dependency)&lt;/div&gt;&lt;div&gt;Die Beziehung heißt:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;✅ 1. UML‑Bezeichnung&lt;/div&gt;&lt;div&gt;Dependency (Abhängigkeit)&lt;/div&gt;&lt;div&gt;oder&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Typed Attribute (Attribut mit Klassentyp)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;✅ 2. Bedeutung&lt;/div&gt;&lt;div&gt;Eine Klasse nutzt eine andere Klasse als Datentyp, ohne sie zu besitzen oder zu verwalten.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Beispiel:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Klasse Adresse wird nur als Datentyp in Person verwendet&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Person hat ein Attribut adresse: Adresse&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Das ist keine Aggregation und keine Komposition, weil Person die Adresse nicht „besitzt“ oder „verwaltet“, sondern nur verwendet.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;📘 UML‑Darstellung&lt;/div&gt;&lt;div&gt;Variante A: Als Attribut (üblichste Form)&lt;/div&gt;&lt;div&gt;Code&lt;/div&gt;&lt;div&gt;+-----------------------+&lt;/div&gt;&lt;div&gt;|&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Person&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;|&lt;/div&gt;&lt;div&gt;+-----------------------+&lt;/div&gt;&lt;div&gt;| - adresse: Adresse&amp;nbsp; &amp;nbsp; |&lt;/div&gt;&lt;div&gt;+-----------------------+&lt;/div&gt;&lt;div&gt;Das bedeutet:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Person hat ein Attribut vom Typ Adresse&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Adresse wird als Datentyp verwendet&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;UML‑Beziehung (optional):&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Code&lt;/div&gt;&lt;div&gt;Person -----&amp;gt; Adresse&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;lt;&amp;lt;use&amp;gt;&amp;gt;&lt;/div&gt;&lt;div&gt;📘 Variante B: Dependency‑Pfeil (wenn nur Datentyp, keine Speicherung)&lt;/div&gt;&lt;div&gt;Wenn die Klasse nur kurz verwendet wird (z. B. als Parameter):&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Code&lt;/div&gt;&lt;div&gt;Person&amp;nbsp; ---------&amp;gt;&amp;nbsp; Adresse&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;lt;&amp;lt;dependency&amp;gt;&amp;gt;&lt;/div&gt;&lt;div&gt;Das bedeutet:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Person kennt Adresse&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Person hängt davon ab, weil sie Adresse als Typ nutzt&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;aber Person besitzt Adresse nicht&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;🧭 Welche Beziehung ist es NICHT?&lt;/div&gt;&lt;div&gt;Beziehung&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Warum nicht?&lt;/div&gt;&lt;div&gt;Aggregation&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;würde bedeuten, dass Person Adresse „enthält“&lt;/div&gt;&lt;div&gt;Komposition&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;würde bedeuten, dass Adresse ohne Person nicht existiert&lt;/div&gt;&lt;div&gt;Vererbung&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;völlig anderer Zweck&lt;/div&gt;&lt;div&gt;Assoziation mit Multiplikation&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;nur nötig, wenn Adresse gespeichert wird&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;🎯 Zusammenfassung&lt;/div&gt;&lt;div&gt;Wenn eine Klasse nur als Datentyp für eine andere Klasse dient, heißt das in UML:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;👉 Dependency (Verwendungsbeziehung)&lt;/div&gt;&lt;div&gt;oder&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;👉 Attributtypisierung (Typed Attribute)&lt;/div&gt;&lt;div&gt;Darstellung:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Code&lt;/div&gt;&lt;div&gt;Person -----&amp;gt; Adresse&lt;/div&gt;&lt;div&gt;&amp;lt;&amp;lt;use&amp;gt;&amp;gt;&lt;/div&gt;&lt;div&gt;oder als Attribut:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Code&lt;/div&gt;&lt;div&gt;adresse: Adresse&lt;/div&gt;" vertex="1">
          <mxGeometry height="1120" width="520" x="40" y="90" as="geometry" />
        </mxCell>
        <mxCell id="JwBW0XjGU_Lk8adR58iQ-76" parent="tXCr_LoeB6MjJ_MeRAy6-17" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;div&gt;✅ 1. Klasse als Datentyp (Value Object)&lt;/div&gt;&lt;div&gt;Beispiel: Du willst nur bestimmte Strings erlauben, z. B. &quot;rot&quot;, &quot;grün&quot;, &quot;blau&quot;.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;php&lt;/div&gt;&lt;div&gt;class Farbe {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; private string $wert;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; private const ERLAUBT = [&quot;rot&quot;, &quot;grün&quot;, &quot;blau&quot;];&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public function __construct(string $wert) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; if (!in_array($wert, self::ERLAUBT, true)) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; throw new InvalidArgumentException(&quot;Ungültige Farbe: $wert&quot;);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $this-&amp;gt;wert = $wert;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public function getWert(): string {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; return $this-&amp;gt;wert;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;➡️ Diese Klasse gibt nichts Besonderes zurück, außer dass sie den Wert kapselt&amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;➡️ Sie prüft, ob der Wert erlaubt ist&lt;/div&gt;&lt;div&gt;➡️ Sie ist selbst der Datentyp&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;✅ 2. Array, das nur diese Klasse enthält&lt;/div&gt;&lt;div&gt;php&lt;/div&gt;&lt;div&gt;class FarbListe {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; /** @var Farbe[] */&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; private array $farben = [];&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public function add(Farbe $farbe): void {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $this-&amp;gt;farben[] = $farbe;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; /** @return Farbe[] */&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public function getAlle(): array {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; return $this-&amp;gt;farben;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;➡️ Das Array enthält nur Objekte vom Typ Farbe&amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;➡️ Du kannst keinen falschen Wert hinzufügen&lt;/div&gt;&lt;div&gt;➡️ Die Klasse Farbe garantiert, dass der Wert gültig ist&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;📘 UML‑Darstellung&lt;/div&gt;&lt;div&gt;Code&lt;/div&gt;&lt;div&gt;+-----------------------+&lt;/div&gt;&lt;div&gt;|&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Farbe&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; |&lt;/div&gt;&lt;div&gt;+-----------------------+&lt;/div&gt;&lt;div&gt;| - wert: String&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; |&lt;/div&gt;&lt;div&gt;+-----------------------+&lt;/div&gt;&lt;div&gt;| + __construct(wert)&amp;nbsp; &amp;nbsp;|&lt;/div&gt;&lt;div&gt;| + getWert(): String&amp;nbsp; &amp;nbsp;|&lt;/div&gt;&lt;div&gt;+-----------------------+&lt;/div&gt;&lt;div&gt;&amp;lt;&amp;lt;constraint&amp;gt;&amp;gt; wert ∈ {rot, grün, blau}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;+---------------------------+&lt;/div&gt;&lt;div&gt;|&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;FarbListe&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;|&lt;/div&gt;&lt;div&gt;+---------------------------+&lt;/div&gt;&lt;div&gt;| - farben: Farbe[0..*]&amp;nbsp; &amp;nbsp; &amp;nbsp;|&lt;/div&gt;&lt;div&gt;+---------------------------+&lt;/div&gt;&lt;div&gt;| + add(f: Farbe): void&amp;nbsp; &amp;nbsp; &amp;nbsp;|&lt;/div&gt;&lt;div&gt;| + getAlle(): Farbe[]&amp;nbsp; &amp;nbsp; &amp;nbsp; |&lt;/div&gt;&lt;div&gt;+---------------------------+&lt;/div&gt;&lt;div&gt;Beziehung:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Code&lt;/div&gt;&lt;div&gt;FarbListe 1 ---- 0..* Farbe&lt;/div&gt;&lt;div&gt;🎯 Fazit&lt;/div&gt;&lt;div&gt;Eine Klasse muss nichts Besonderes zurückgeben, um als Datentyp zu dienen&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Sie repräsentiert den Wert selbst&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Du kannst damit Arrays bauen, die nur erlaubte Werte enthalten&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Das ist die professionellste Lösung in PHP (Value‑Object‑Pattern)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Wenn du willst, kann ich dir:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;ein komplettes UML‑Diagramm&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;eine generische Version für beliebige erlaubte Werte&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;oder ein konkretes Beispiel für deinen Anwendungsfall&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;erstellen.&lt;/div&gt;" vertex="1">
          <mxGeometry height="1250" width="480" x="655" y="90" as="geometry" />
        </mxCell>
        <mxCell id="JwBW0XjGU_Lk8adR58iQ-77" parent="tXCr_LoeB6MjJ_MeRAy6-17" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;ERLAUBT ist in deinem Beispiel keine Klasse, sondern eine Klassenkonstante.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Ich zeige dir genau, was das bedeutet und wie man es einordnet.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;🎯 Was ist private const ERLAUBT = [&quot;rot&quot;, &quot;grün&quot;, &quot;blau&quot;];?&lt;/div&gt;&lt;div&gt;Das ist eine Konstante innerhalb einer Klasse.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;🔹 Konstante&lt;/div&gt;&lt;div&gt;Ein fester Wert, der sich nie ändert&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Wird mit const definiert&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Kann Array, String, Zahl, Boolean usw. sein&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Wird ohne $ geschrieben&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;🔹 Klassenkonstante&lt;/div&gt;&lt;div&gt;Gehört zur Klasse, nicht zu einem Objekt&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Wird mit self::ERLAUBT aufgerufen&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Wird oft für erlaubte Werte, Konfiguration, Enum‑ähnliche Werte genutzt&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;📘 Beispiel erklärt&lt;/div&gt;&lt;div&gt;php&lt;/div&gt;&lt;div&gt;class Farbe {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; private const ERLAUBT = [&quot;rot&quot;, &quot;grün&quot;, &quot;blau&quot;];&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;👉 ERLAUBT ist also:&lt;/div&gt;&lt;div&gt;eine Konstante&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;vom Typ Array&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;privat (nur innerhalb der Klasse sichtbar)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;enthält Strings, die erlaubt sind&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Sie ist kein Datentyp, keine Klasse, keine Variable.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;🧠 Warum benutzt man das?&lt;/div&gt;&lt;div&gt;Damit du zentral festlegen kannst, welche Werte gültig sind.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Beispiel:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;php&lt;/div&gt;&lt;div&gt;public function __construct(string $wert) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; if (!in_array($wert, self::ERLAUBT, true)) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; throw new InvalidArgumentException(&quot;Ungültige Farbe&quot;);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; $this-&amp;gt;wert = $wert;&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;➡️ Die Klasse prüft selbst, ob der Wert erlaubt ist&lt;/div&gt;&lt;div&gt;➡️ Du kannst keine falschen Werte erzeugen&lt;/div&gt;&lt;div&gt;➡️ Die Klasse wird zu einem eigenen Datentyp&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;📘 UML‑Darstellung&lt;/div&gt;&lt;div&gt;Code&lt;/div&gt;&lt;div&gt;+-----------------------+&lt;/div&gt;&lt;div&gt;|&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Farbe&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; |&lt;/div&gt;&lt;div&gt;+-----------------------+&lt;/div&gt;&lt;div&gt;| - wert: String&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; |&lt;/div&gt;&lt;div&gt;| - ERLAUBT: String[] {const} |&lt;/div&gt;&lt;div&gt;+-----------------------+&lt;/div&gt;&lt;div&gt;🎯 Kurzfassung&lt;/div&gt;&lt;div&gt;Element&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Bedeutung&lt;/div&gt;&lt;div&gt;const&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Konstante (unveränderbar)&lt;/div&gt;&lt;div&gt;private&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;nur in der Klasse sichtbar&lt;/div&gt;&lt;div&gt;ERLAUBT&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Name der Konstante&lt;/div&gt;&lt;div&gt;[&quot;rot&quot;,&quot;grün&quot;,&quot;blau&quot;]&lt;span style=&quot;white-space:pre&quot;&gt;&#x9;&lt;/span&gt;Array aus Strings&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="1020" width="440" x="1195" y="190" as="geometry" />
        </mxCell>
