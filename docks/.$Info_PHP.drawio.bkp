        <mxCell id="UhoqVoWdSPM1nPK_Kb_X-34" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;fontSize=15;" value="&lt;div&gt;&lt;div&gt;backend/src/App/Config/routes.php&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Enthält globale Routen, die unabhängig von Modulen funktionieren&lt;/li&gt;&lt;li&gt;Wird beim Start der App geladen&lt;/li&gt;&lt;li&gt;Auth‑Modul kann trotzdem eigene Routen haben (AuthRoutes.php)&lt;/li&gt;&lt;li&gt;App‑Modul kann später weitere globale Routen hinzufügen&lt;/li&gt;&lt;li&gt;Router liest diese Datei ein und registriert die Routen automatisch&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;lt;?php&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;use App\Auth\AuthController;&lt;/div&gt;&lt;div&gt;use App\App\AppController; // falls du später eine Startseite hast&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;return [&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; // GET‑Routen&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &#39;GET&#39; =&amp;gt; [&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &#39;/&#39; =&amp;gt; [AppController::class, &#39;home&#39;],&amp;nbsp; &amp;nbsp;// optional&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; ],&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; // POST‑Routen&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &#39;POST&#39; =&amp;gt; [&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &#39;/login&#39; =&amp;gt; [AuthController::class, &#39;login&#39;],&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &#39;/logout&#39; =&amp;gt; [AuthController::class, &#39;logout&#39;], // optional&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; ],&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;];&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="530" width="520" x="1410" y="300" as="geometry" />
        </mxCell>
