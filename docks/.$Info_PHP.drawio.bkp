        <mxCell id="KFwVIHRTOtqEWXRbHIaX-26" parent="KFwVIHRTOtqEWXRbHIaX-51" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;🧱 Model&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;div style=&quot;&quot;&gt;Was es ist:&amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;Ein Model repräsentiert ein Datenobjekt (z. B. User, Product, Order).&lt;/div&gt;&lt;div style=&quot;&quot;&gt;Es enthält typischerweise nur Eigenschaften und manchmal kleine Hilfsmethoden.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;Beispiel:&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div&gt;class User {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public int $id;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public string $email;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public string $password;&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;strong&gt;Kurz gesagt:&lt;/strong&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;Model = „Ein Objekt, das Daten repräsentiert.“&lt;/div&gt;&lt;/div&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="460" x="40" y="1180" as="geometry" />
        </mxCell>
        <mxCell id="KFwVIHRTOtqEWXRbHIaX-27" edge="1" parent="KFwVIHRTOtqEWXRbHIaX-51" source="KFwVIHRTOtqEWXRbHIaX-24" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="KFwVIHRTOtqEWXRbHIaX-26" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
