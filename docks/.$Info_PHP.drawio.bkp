        <mxCell id="yRz0JCtdacoU9AkxJJ5S-4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="Wofür benutzt man &lt;code&gt;header()&lt;/code&gt;?&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;🔁 1. Weiterleitungen (Redirects)&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;header(&quot;Location: /login.php&quot;);&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;exit;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;📄 2. Content‑Typ festlegen&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;header(&quot;Content-Type: application/json&quot;);&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;echo json_encode($data);&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;🔒 3. Downloads erzwingen&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;header(&quot;Content-Disposition: attachment; filename=\&quot;report.pdf\&quot;&quot;);&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;🚫 4. Caching steuern&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;header(&quot;Cache-Control: no-cache&quot;);&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="230" width="400" x="1480" y="2550" as="geometry" />
        </mxCell>
        <mxCell id="yRz0JCtdacoU9AkxJJ5S-5" edge="1" parent="1" source="wo0p1ZfNdt3Z2teXgPPR-35" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="yRz0JCtdacoU9AkxJJ5S-4" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="1040" y="750" as="sourcePoint" />
            <mxPoint x="1090" y="700" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="yRz0JCtdacoU9AkxJJ5S-6" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🎯 Kernidee&lt;/div&gt;&lt;div&gt;header() benutzt du immer dann, wenn dein Backend (PHP) eine HTTP‑Antwort an das Frontend sendet und diese Antwort bestimmte Eigenschaften haben soll.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Das Frontend (React, Axios) stellt eine Anfrage →&lt;/div&gt;&lt;div&gt;Das Backend (PHP) antwortet →&lt;/div&gt;&lt;div&gt;Bevor PHP diese Antwort sendet, kannst du mit header() festlegen:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Welcher Content‑Type zurückkommt&lt;/li&gt;&lt;li&gt;Ob ein Redirect passieren soll&lt;/li&gt;&lt;li&gt;Ob ein Cookie gesetzt wird&lt;/li&gt;&lt;li&gt;Welche CORS‑Regeln gelten&lt;/li&gt;&lt;li&gt;Ob die Antwort gecached werden darf&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="370" x="-730" y="2560" as="geometry" />
        </mxCell>
        <mxCell id="yRz0JCtdacoU9AkxJJ5S-7" edge="1" parent="1" source="wo0p1ZfNdt3Z2teXgPPR-35" style="endArrow=classic;html=1;rounded=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" target="yRz0JCtdacoU9AkxJJ5S-6" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="10" y="1050" as="sourcePoint" />
            <mxPoint x="-330" y="1340" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="pKHLCEEhMPk__EJ80ix6-3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🧠 Was passiert technisch?&lt;/div&gt;&lt;div&gt;Wenn session_start() ausgeführt wird:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;PHP prüft, ob der Browser bereits ein Session‑Cookie (PHPSESSID) geschickt hat.&lt;/li&gt;&lt;li&gt;Wenn ja, lädt PHP die gespeicherten Session‑Daten.&lt;/li&gt;&lt;li&gt;Wenn nein, erzeugt PHP eine neue Session und sendet ein Cookie zurück.&lt;/li&gt;&lt;li&gt;Danach steht dir das globale Array $_SESSION zur Verfügung.&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="510" x="-1400" y="1070" as="geometry" />
        </mxCell>
        <mxCell id="pKHLCEEhMPk__EJ80ix6-15" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="320" width="610" x="-1920" y="2510" as="geometry" />
        </mxCell>
