        <mxCell id="rr-h6olEAMJjaFIh81AH-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ein führender Backslash &lt;code&gt;\&lt;/code&gt; bedeutet in PHP einen &lt;strong&gt;absoluten Pfad&lt;/strong&gt;, aber PHP interpretiert ihn nicht wie Windows.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Backslashes &lt;code&gt;\&lt;/code&gt; sind in PHP-Strings &lt;strong&gt;Escape-Zeichen&lt;/strong&gt; und müssen doppelt geschrieben werden (&lt;code&gt;\\&lt;/code&gt;), sonst entstehen Fehler.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Es fehlt der &lt;strong&gt;Dateiname&lt;/strong&gt;, z. B. &lt;code&gt;index.php&lt;/code&gt; oder &lt;code&gt;config.php&lt;/code&gt;.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;✅ Korrekte Varianten&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;1. Windows-Pfad (mit doppelten Backslashes)&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;include_once(&#39;C:\\BrauereiControl_PHP_React\\brauerei\\backend_php\\datei.php&#39;);&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;div&gt;2. Besser: Forward Slashes verwenden (funktioniert überall)&lt;/div&gt;&lt;/li&gt;&lt;li&gt;&lt;div&gt;&lt;div&gt;include_once(&#39;C:/BrauereiControl_PHP_React/brauerei/backend_php/datei.php&#39;);&lt;/div&gt;&lt;/div&gt;&lt;/li&gt;&lt;li&gt;&lt;div&gt;&lt;h3&gt;&lt;strong&gt;3. Relativer Pfad&lt;/strong&gt;&lt;/h3&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn dein PHP-Skript im Projekt liegt:&lt;/span&gt;&lt;/p&gt;&lt;/div&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;include_once __DIR__ . &#39;/brauerei/backend_php/datei.php&#39;;&lt;br/&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;div&gt;&lt;h2&gt;💡 Empfehlung&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Nutze &lt;code&gt;__DIR__&lt;/code&gt;&lt;strong&gt; + Forward Slashes&lt;/strong&gt;, das ist am zuverlässigsten und portabel.&lt;/span&gt;&lt;/p&gt;&lt;/div&gt;&lt;/li&gt;" vertex="1">
          <mxGeometry height="400" width="520" x="1870" y="170" as="geometry" />
        </mxCell>
        <mxCell id="rr-h6olEAMJjaFIh81AH-2" edge="1" parent="1" source="wo0p1ZfNdt3Z2teXgPPR-6" style="endArrow=classic;html=1;rounded=0;entryX=-0.001;entryY=0.108;entryDx=0;entryDy=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryPerimeter=0;" target="rr-h6olEAMJjaFIh81AH-1" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="1310" y="220" as="sourcePoint" />
            <mxPoint x="1520" y="220" as="targetPoint" />
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
