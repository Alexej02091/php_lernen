  <diagram id="ofzGfh1XgNIzTL7JffMq" name="Apache">
    <mxGraphModel dx="1426" dy="849" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="nF5m_557PnTUMMYEuS87-50" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="1150" width="800" x="14" y="10" as="geometry" />
        </mxCell>
        <mxCell id="fzdHlyg6hQNtErouiBy8-1" parent="nF5m_557PnTUMMYEuS87-50" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;width=120;height=30;" value="🌐 Was ist Apache?" vertex="1">
          <mxGeometry height="1150" width="800" as="geometry" />
        </mxCell>
        <mxCell id="nF5m_557PnTUMMYEuS87-1" parent="nF5m_557PnTUMMYEuS87-50" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🔥 Apache = Webserver-Software&lt;/div&gt;&lt;div&gt;Apache (voll: Apache HTTP Server) ist ein Programm, das auf einem Server läuft und:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;HTTP‑Anfragen vom Browser entgegennimmt&lt;/li&gt;&lt;li&gt;entscheidet, welche Datei oder welches Skript ausgeführt werden soll&lt;/li&gt;&lt;li&gt;PHP‑Code an den PHP‑Interpreter weitergibt&lt;/li&gt;&lt;li&gt;HTML, JSON oder andere Inhalte zurück an den Browser sendet&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="470" x="10" y="40" as="geometry" />
        </mxCell>
        <mxCell id="nF5m_557PnTUMMYEuS87-2" parent="nF5m_557PnTUMMYEuS87-50" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="🧠 Was Apache konkret macht&lt;div&gt;&lt;div&gt;📥 1. Browser schickt eine Anfrage&lt;/div&gt;&lt;div&gt;Beispiel:&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;GET /login&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;🧭 2. Apache entscheidet anhand der Konfiguration&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Welche Datei soll ausgeliefert werden?&lt;/li&gt;&lt;li&gt;Welche Route soll angesprochen werden?&lt;/li&gt;&lt;li&gt;Soll PHP ausgeführt werden?&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;div&gt;⚙️ 3. Apache ruft PHP auf&lt;/div&gt;&lt;div&gt;Apache selbst versteht keinen PHP‑Code.&lt;/div&gt;&lt;div&gt;Dafür nutzt es:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;mod_php (älter, aber verbreitet)&lt;/li&gt;&lt;li&gt;PHP-FPM (modern, schneller, empfohlen)&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;📤 4. Apache sendet die Antwort zurück&lt;/div&gt;&lt;div&gt;Das kann sein:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;HTML&lt;/li&gt;&lt;li&gt;JSON (z. B. API‑Response)&lt;/li&gt;&lt;li&gt;Bilder, CSS, JS&lt;/li&gt;&lt;li&gt;Fehlerseiten&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="350" width="300" x="10" y="180" as="geometry" />
        </mxCell>
        <mxCell id="nF5m_557PnTUMMYEuS87-4" parent="nF5m_557PnTUMMYEuS87-50" style="shape=table;startSize=0;container=1;collapsible=0;childLayout=tableLayout;fontSize=16;" value="" vertex="1">
          <mxGeometry height="240" width="470" x="320" y="180" as="geometry" />
        </mxCell>
        <mxCell id="nF5m_557PnTUMMYEuS87-5" parent="nF5m_557PnTUMMYEuS87-4" style="shape=tableRow;horizontal=0;startSize=0;swimlaneHead=0;swimlaneBody=0;strokeColor=inherit;top=0;left=0;bottom=0;right=0;collapsible=0;dropTarget=0;fillColor=none;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontSize=16;" value="" vertex="1">
          <mxGeometry height="40" width="470" as="geometry" />
        </mxCell>
        <mxCell id="nF5m_557PnTUMMYEuS87-6" parent="nF5m_557PnTUMMYEuS87-5" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;fontSize=16;" value="Vorteil" vertex="1">
          <mxGeometry height="40" width="126" as="geometry">
            <mxRectangle height="40" width="126" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
