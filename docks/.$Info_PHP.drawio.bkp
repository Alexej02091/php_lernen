          <mxGeometry height="990" width="1040" as="geometry" />
        </mxCell>
        <mxCell id="pKHLCEEhMPk__EJ80ix6-167" parent="pKHLCEEhMPk__EJ80ix6-181" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🎯 2. Warum brauchst du überhaupt eine Session?&lt;/div&gt;&lt;div&gt;Weil du willst, dass der User eingeloggt bleibt, auch wenn:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;er eine neue Seite lädt&lt;/li&gt;&lt;li&gt;er eine API‑Route aufruft&lt;/li&gt;&lt;li&gt;er Daten abfragt&lt;/li&gt;&lt;li&gt;er seine Rolle nutzt&lt;/li&gt;&lt;li&gt;er Funktionen ausführt&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Ohne Session müsste der User bei jedem Request Name + Passwort mitschicken.&lt;/div&gt;&lt;div&gt;Das wäre unsicher und unpraktisch.&lt;/div&gt;&lt;div&gt;Die Session ist einfach ein Speicherplatz im Backend, der dem User zugeordnet wird.&lt;/div&gt;" vertex="1">
          <mxGeometry height="190" width="500" x="10" y="220" as="geometry" />
        </mxCell>
        <mxCell id="pKHLCEEhMPk__EJ80ix6-168" parent="pKHLCEEhMPk__EJ80ix6-181" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🎯 3. Wer erzeugt die Session?&lt;/div&gt;&lt;div&gt;Ganz klar:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;✔️ Das Backend (PHP) erzeugt die Session-ID.&lt;/div&gt;&lt;div&gt;Der Browser erzeugt nichts.&lt;/div&gt;&lt;div&gt;Er speichert nur das Cookie, das PHP ihm gibt.&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="500" x="10" y="440" as="geometry" />
        </mxCell>
        <mxCell id="pKHLCEEhMPk__EJ80ix6-169" parent="pKHLCEEhMPk__EJ80ix6-181" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🎯 5. Was bedeutet das für dich?&lt;/div&gt;&lt;div&gt;Du musst dir merken:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;✔️ Der Browser erzeugt KEINE Session&lt;/div&gt;&lt;div&gt;✔️ Das Backend erzeugt die Session&lt;/div&gt;&lt;div&gt;✔️ Der Browser speichert nur das Cookie&lt;/div&gt;&lt;div&gt;✔️ Das Cookie sagt PHP: „Lade meine Session-Daten“&lt;/div&gt;&lt;div&gt;✔️ In der Session speicherst DU, ob jemand eingeloggt ist&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="500" x="530" y="40" as="geometry" />
        </mxCell>
        <mxCell id="pKHLCEEhMPk__EJ80ix6-170" parent="pKHLCEEhMPk__EJ80ix6-181" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="🎯 &lt;strong&gt;7. Warum ist das für dein Projekt wichtig?&lt;/strong&gt;&lt;div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Weil du ein System baust, das:&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;ul&gt;&lt;li&gt;&lt;b&gt;Rollen lädt&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Module abhängig von Rollen aktiviert&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Funktionen abhängig vom User bereitstellt&lt;/b&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Das geht nur, wenn das Backend weiß, wer du bist — und das geht nur über Sessions (oder JWT, aber das ist ein anderes Thema).&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="500" x="530" y="670" as="geometry" />
        </mxCell>
        <mxCell id="pKHLCEEhMPk__EJ80ix6-171" parent="pKHLCEEhMPk__EJ80ix6-181" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🎯 6. Dein Login‑Flow in sauberer Form&lt;/div&gt;&lt;div&gt;🔐 Login (POST /login)&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;session_start();&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;if ($userFound &amp;amp;&amp;amp; password_verify($pw, $hash)) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; session_regenerate_id(true); // Sicherheit&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; $_SESSION[&#39;user_id&#39;] = $user[&#39;id&#39;];&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; $_SESSION[&#39;role&#39;] = $user[&#39;role&#39;];&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; echo json_encode([&quot;success&quot; =&amp;gt; true]);&lt;/div&gt;&lt;div&gt;} else {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; echo json_encode([&quot;success&quot; =&amp;gt; false]);&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;🔍 Auth‑Check (z. B. GET /me)&lt;/div&gt;&lt;div&gt;&lt;div&gt;session_start();&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;if (!isset($_SESSION[&#39;user_id&#39;])) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; http_response_code(401);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; echo &quot;Not logged in&quot;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; exit;&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;echo json_encode([&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &quot;id&quot; =&amp;gt; $_SESSION[&#39;user_id&#39;],&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &quot;role&quot; =&amp;gt; $_SESSION[&#39;role&#39;]&lt;/div&gt;&lt;div&gt;]);&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;🚪 Logout&lt;/div&gt;&lt;div&gt;&lt;div&gt;session_start();&lt;/div&gt;&lt;div&gt;session_destroy();&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="460" width="500" x="530" y="190" as="geometry" />
        </mxCell>
        <mxCell id="pKHLCEEhMPk__EJ80ix6-172" parent="pKHLCEEhMPk__EJ80ix6-181" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🎯 4. Wie läuft das technisch ab?&lt;/div&gt;&lt;div&gt;🔹 Schritt 1: User loggt sich ein&lt;/div&gt;&lt;div&gt;Backend prüft DB → alles korrekt.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Dann machst du:&lt;/div&gt;&lt;div&gt;&lt;div&gt;session_start();&lt;/div&gt;&lt;div&gt;$_SESSION[&#39;user_id&#39;] = $user[&#39;id&#39;];&lt;/div&gt;&lt;div&gt;$_SESSION[&#39;role&#39;] = $user[&#39;role&#39;];&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Jetzt ist der User eingeloggt.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;🔹 Schritt 2: PHP sendet ein Cookie zurück&lt;/div&gt;&lt;div&gt;PHP schickt automatisch:&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Set-Cookie: PHPSESSID=abc123xyz&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Der Browser speichert dieses Cookie.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;🔹 Schritt 3: Jeder weitere Request sendet das Cookie mit&lt;/div&gt;&lt;div&gt;Browser schickt automatisch:&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Cookie: PHPSESSID=abc123xyz&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;🔹 Schritt 4: PHP erkennt den User wieder&lt;/div&gt;&lt;div&gt;Du machst:&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;session_start();&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;if (!isset($_SESSION[&#39;user_id&#39;])) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; // nicht eingeloggt&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/div&gt;&lt;div&gt;PHP lädt die Session-Daten anhand der Session-ID.&lt;/div&gt;" vertex="1">
          <mxGeometry height="400" width="500" x="10" y="580" as="geometry" />
        </mxCell>
        <mxCell id="pKHLCEEhMPk__EJ80ix6-174" edge="1" parent="pKHLCEEhMPk__EJ80ix6-181" source="pKHLCEEhMPk__EJ80ix6-6" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="pKHLCEEhMPk__EJ80ix6-167" value="">
