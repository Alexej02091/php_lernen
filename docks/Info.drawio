        </mxCell>
        <mxCell id="KFwVIHRTOtqEWXRbHIaX-17" parent="KFwVIHRTOtqEWXRbHIaX-51" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;width=280;height=30;" value="🧩 Die wichtigsten Architektur‑Bausteine in PHP" vertex="1">
          <mxGeometry height="2300" width="790" as="geometry" />
        </mxCell>
        <mxCell id="KFwVIHRTOtqEWXRbHIaX-18" parent="KFwVIHRTOtqEWXRbHIaX-51" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="🛣️ &lt;strong&gt;Routes&lt;/strong&gt;&lt;div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Was es ist:&amp;nbsp;&amp;nbsp;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Die Routes definieren, welche URL zu welcher Controller‑Methode führt.&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Beispiel:&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;$router-&amp;gt;get(&#39;/login&#39;, [AuthController::class, &#39;showLogin&#39;]);&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;$router-&amp;gt;post(&#39;/login&#39;, [AuthController::class, &#39;login&#39;]);&lt;/div&gt;&lt;div&gt;Kurz gesagt:&lt;/div&gt;&lt;div&gt;Route = „Wenn der Nutzer diese URL aufruft, führe diese Methode aus.“&lt;/div&gt;&lt;/b&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="420" x="40" y="50" as="geometry" />
        </mxCell>
        <mxCell id="KFwVIHRTOtqEWXRbHIaX-19" parent="KFwVIHRTOtqEWXRbHIaX-51" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="🎮 &lt;strong&gt;Controller&lt;/strong&gt;&lt;div&gt;&lt;strong&gt;Was es ist:&lt;/strong&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;Der Controller ist der &lt;strong&gt;Einstiegspunkt&lt;/strong&gt; für eine Anfrage.&lt;br&gt;Er nimmt Request‑Daten entgegen, ruft Services auf und gibt eine Response zurück.&lt;strong&gt;&lt;/strong&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Was er NICHT tun sollte:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;keine Datenbankabfragen&lt;/li&gt;&lt;li&gt;keine Business‑Logik&lt;/li&gt;&lt;li&gt;keine Validierung im großen Stil&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Beispiel:&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;class AuthController {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public function login(Request $request, AuthService $service) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; return $service-&amp;gt;attemptLogin($request-&amp;gt;get(&#39;email&#39;), $request-&amp;gt;get(&#39;password&#39;));&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;strong&gt;Kurz gesagt:&lt;/strong&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Controller = „Koordinator“ der Anfrage.&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="280" width="490" x="260" y="210" as="geometry" />
        </mxCell>
        <mxCell id="KFwVIHRTOtqEWXRbHIaX-20" edge="1" parent="KFwVIHRTOtqEWXRbHIaX-51" source="KFwVIHRTOtqEWXRbHIaX-18" style="endArrow=classic;html=1;rounded=0;exitX=0.75;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="KFwVIHRTOtqEWXRbHIaX-19" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="240" y="420" as="sourcePoint" />
            <mxPoint x="290" y="370" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="KFwVIHRTOtqEWXRbHIaX-22" parent="KFwVIHRTOtqEWXRbHIaX-51" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="🧠 &lt;strong&gt;Service&lt;/strong&gt;&lt;div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Was es ist:&amp;nbsp;&amp;nbsp;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Der Service enthält die Business‑Logik.&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Hier passiert das „Denken“ deiner Anwendung.&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Beispiel:&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;class AuthService {&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; public function attemptLogin($email, $password) {&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $user = $this-&amp;gt;userRepository-&amp;gt;findByEmail($email);&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; if (!$user || !password_verify($password, $user-&amp;gt;password)) {&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; throw new AuthException(&quot;Invalid credentials&quot;);&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; return $user;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; }&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;}&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;font-weight: bold;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;font-weight: bold;&quot;&gt;&lt;strong&gt;Kurz gesagt:&lt;/strong&gt;&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;font-weight: bold;&quot;&gt;Service = „Hier steckt die Logik, die Regeln, die Prozesse.“&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="300" width="400" x="40" y="530" as="geometry" />
        </mxCell>
        <mxCell id="KFwVIHRTOtqEWXRbHIaX-23" edge="1" parent="KFwVIHRTOtqEWXRbHIaX-51" source="KFwVIHRTOtqEWXRbHIaX-19" style="endArrow=classic;html=1;rounded=0;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="KFwVIHRTOtqEWXRbHIaX-22" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="160" y="580" as="sourcePoint" />
