        <mxCell id="Whp2AbG9F2wWwhStgsQD-10" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=3;spacingRight=2;" value="&lt;div&gt;&lt;b&gt;require &lt;/b&gt;lädt eine Datei zwingend.&lt;/div&gt;&lt;div&gt;Wenn sie fehlt → Fatal Error, Script stoppt.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;__DIR__&lt;/b&gt; ist ein PHP‑Konstanten-Magic-Keyword.&lt;/div&gt;&lt;div&gt;Es enthält den absoluten Pfad des aktuellen Verzeichnisses, also dort, wo diese Datei liegt.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&#39;../src/vendor/autoload.php&#39; bedeutet:&lt;/div&gt;&lt;div&gt;eine Ebene nach oben, dann in src/vendor/, dann autoload.php&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Du lädst den Composer Autoloader.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Der Autoloader sorgt dafür, dass PHP automatisch Klassen findet, ohne dass du jede Datei manuell einbinden musst.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Beispiel:&lt;/div&gt;&lt;div&gt;Wenn du später new App\App() schreibst, sucht der Autoloader automatisch die Datei, in der diese Klasse definiert ist.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Ohne Autoloader wäre moderne OOP‑Entwicklung in PHP praktisch unmöglich.&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="290" width="430" x="1210" y="-1090" as="geometry" />
        </mxCell>
        <mxCell id="Whp2AbG9F2wWwhStgsQD-11" edge="1" parent="1" source="Whp2AbG9F2wWwhStgsQD-5" style="endArrow=classic;html=1;rounded=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" target="Whp2AbG9F2wWwhStgsQD-10" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="1090" y="-1060" as="sourcePoint" />
            <mxPoint x="1140" y="-1110" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="jShnli8X3TEjpVxSGF65-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=5;" value="&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;$app = new App\App();&lt;/span&gt;&lt;/div&gt;Du erzeugst ein neues Objekt der Klasse &lt;code&gt;App\App&lt;/code&gt;.&lt;div&gt;Der Namespace &lt;code&gt;App&lt;/code&gt; bedeutet:&amp;nbsp;&lt;/div&gt;&lt;div&gt;Die Klasse liegt wahrscheinlich unter:&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;src/App/App.php&lt;/span&gt;&lt;/div&gt;&lt;div&gt;Zweck dieser Zeile&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;Du startest deine Haupt‑Anwendungsklasse.&lt;br&gt;Das ist der zentrale Einstiegspunkt deiner App — vergleichbar mit &lt;code&gt;main()&lt;/code&gt; in Java oder C++&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="430" x="1210" y="-790" as="geometry" />
        </mxCell>
