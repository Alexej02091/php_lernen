        <mxCell id="wo0p1ZfNdt3Z2teXgPPR-12" parent="wo0p1ZfNdt3Z2teXgPPR-10" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;fontSize=16;align=left;spacingLeft=5;" value="Der Autoloader sorgt dafür, dass PHP automatisch Klassen findet, ohne dass du jede Datei manuell einbinden musst.&lt;div&gt;Wenn du später &lt;code&gt;new App\App()&lt;/code&gt; schreibst, sucht der Autoloader automatisch die Datei, in der diese Klasse definiert ist.&lt;/div&gt;" vertex="1">
