        <mxCell id="w7DwOR1FbQZn8UWmJBvV-10" parent="w7DwOR1FbQZn8UWmJBvV-57" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;🧱 Die wichtigsten Begriffe in PHP‑Architektur (einfach erklärt)&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;🟦 1. Controller&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Der Controller ist der Eingangspunkt deiner Anwendung.&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Er:&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;ul&gt;&lt;li&gt;&lt;b&gt;nimmt Requests entgegen&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;prüft Berechtigungen&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;ruft Services auf&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;gibt eine Antwort zurück (JSON, HTML, Redirect …)&lt;/b&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Beispiel:&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;div&gt;class UserController {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public function create() {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $this-&amp;gt;userService-&amp;gt;createUser();&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="255" width="380" x="5" as="geometry" />
        </mxCell>
        <mxCell id="w7DwOR1FbQZn8UWmJBvV-11" parent="w7DwOR1FbQZn8UWmJBvV-57" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;🟩 2. Model&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Ein Model ist ein Datenobjekt, das deine Entitäten beschreibt.&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Beispiele:&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;ul&gt;&lt;li&gt;&lt;b&gt;User&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Wohnung&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Zimmer&lt;/b&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Ein Model enthält keine Logik, nur Daten + Validierung.&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;div&gt;class User {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public int $id;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public string $name;&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="210" width="382.5" x="2.5" y="270" as="geometry" />
        </mxCell>
        <mxCell id="w7DwOR1FbQZn8UWmJBvV-12" parent="w7DwOR1FbQZn8UWmJBvV-57" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;🟧 3. Repository&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Das Repository ist für Datenbankzugriffe zuständig.&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Es:&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;ul&gt;&lt;li&gt;&lt;b&gt;führt SQL‑Queries aus&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;holt Daten&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;speichert Daten&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;gibt Models zurück&lt;/b&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Beispiel:&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;div&gt;class UserRepository {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public function findById(int $id): User {}&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public function save(User $user): void {}&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="230" width="385" y="515" as="geometry" />
