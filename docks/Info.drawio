        <mxCell id="dKPXDUbTOnWkBQBTvOVH-35" parent="BuUvHkD3C2r66v8NpPr0-4" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=6;fontSize=15;" value="&lt;div style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Beispiel: Ein Hook in Aktion&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 127, 255);&quot;&gt;function &lt;/font&gt;&lt;font style=&quot;color: rgb(255, 181, 112);&quot;&gt;BierCounter&lt;/font&gt;() {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &lt;font style=&quot;color: rgb(0, 127, 255);&quot;&gt;const &lt;/font&gt;[&lt;font style=&quot;color: rgb(0, 255, 255);&quot;&gt;count&lt;/font&gt;, setCount] = &lt;font style=&quot;color: rgb(255, 102, 255);&quot;&gt;useState&lt;/font&gt;(&lt;font style=&quot;color: rgb(255, 128, 0);&quot;&gt;0&lt;/font&gt;);&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &lt;font style=&quot;color: rgb(255, 102, 255);&quot;&gt;useEffect&lt;/font&gt;(() =&amp;gt; {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;font style=&quot;color: rgb(103, 171, 159);&quot;&gt;console&lt;/font&gt;.&lt;font style=&quot;color: rgb(255, 102, 255);&quot;&gt;log&lt;/font&gt;(&lt;font style=&quot;color: rgb(0, 153, 0);&quot;&gt;&quot;Count geändert:&quot;&lt;/font&gt;, &lt;font style=&quot;color: rgb(0, 255, 255);&quot;&gt;count&lt;/font&gt;);&lt;/div&gt;&lt;div&gt;&amp;nbsp; }, [&lt;font style=&quot;color: rgb(0, 255, 255);&quot;&gt;count&lt;/font&gt;]&lt;font style=&quot;color: rgb(255, 102, 255);&quot;&gt;)&lt;/font&gt;;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp;&lt;font style=&quot;color: rgb(255, 102, 255);&quot;&gt; &lt;font style=&quot;color: rgb(255, 102, 255);&quot;&gt;return &lt;/font&gt;(&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;lt;&lt;font style=&quot;color: rgb(0, 127, 255);&quot;&gt;button &lt;/font&gt;&lt;font style=&quot;color: rgb(103, 171, 159);&quot;&gt;onClick&lt;/font&gt;={() =&amp;gt; setCount(&lt;font style=&quot;color: rgb(0, 255, 255);&quot;&gt;count &lt;/font&gt;+ 1)}&amp;gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; Bier getrunken: {&lt;font style=&quot;color: rgb(0, 255, 255);&quot;&gt;count&lt;/font&gt;}&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;lt;/&lt;font style=&quot;color: rgb(0, 127, 255);&quot;&gt;button&lt;/font&gt;&amp;gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &lt;font style=&quot;color: rgb(255, 102, 255);&quot;&gt;)&lt;/font&gt;;&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;useState -&amp;gt; speichert Daten&lt;/div&gt;&lt;div&gt;useEffect -&amp;gt; reagiert auf Änderungen&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="380" width="341" x="59" y="600" as="geometry" />
        </mxCell>
        <mxCell id="dKPXDUbTOnWkBQBTvOVH-36" parent="BuUvHkD3C2r66v8NpPr0-4" style="rounded=0;whiteSpace=wrap;html=1;fontStyle=1;strokeColor=#FF0000;" value="Hooks=React-Superkräfte für Funktionskomponenten" vertex="1">
          <mxGeometry height="40" width="280" x="500" y="150" as="geometry" />
        </mxCell>
        <mxCell id="dKPXDUbTOnWkBQBTvOVH-37" parent="BuUvHkD3C2r66v8NpPr0-4" style="rounded=0;whiteSpace=wrap;html=1;align=left;fontSize=13;" value="Warum heißen sie &quot;Hooks&quot;?&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Weil sie sich in Reacts internen Ablauf einhaken (engl. to hook into).&lt;/div&gt;&lt;div&gt;Sie sagen React:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&quot;Wenn sich dieser State ändert, render neu.&quot;&lt;/li&gt;&lt;li&gt;Wenn diese Komponente geladen wird, führe diesen Effekt aus.&quot;&lt;/li&gt;&lt;li&gt;Wenn diese Props sich ändern, berechne etwas neu.&quot;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="310" x="430" y="600" as="geometry" />
        </mxCell>
