        <mxCell id="yRz0JCtdacoU9AkxJJ5S-3" parent="yRz0JCtdacoU9AkxJJ5S-1" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;fontSize=16;align=left;spacingLeft=5;verticalAlign=top;" value="&lt;div&gt;session_start() startet eine neue Session oder setzt eine bestehende Session fort.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Eine Session ist ein Mechanismus, mit dem PHP Daten über mehrere Seitenaufrufe hinweg speichern kann — z. B.:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;ob ein Benutzer eingeloggt ist&lt;/li&gt;&lt;li&gt;seine User‑ID&lt;/li&gt;&lt;li&gt;Einstellungen&lt;/li&gt;&lt;li&gt;Warenkorb‑Daten&lt;/li&gt;&lt;li&gt;usw.&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Ohne Session wären HTTP‑Requests komplett zustandslos.&lt;/div&gt;" vertex="1">
          <mxGeometry height="240" width="740" x="413" as="geometry">
            <mxRectangle height="240" width="740" as="alternateBounds" />
          </mxGeometry>
