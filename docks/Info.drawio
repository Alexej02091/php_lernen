        <mxCell id="iud6hWaGE5kNCWCGpW4J-3" parent="_NgpSxgU6XjmauKNE8cU-3" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;width=150;height=30;" value="Komponente" vertex="1">
