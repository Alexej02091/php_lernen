        <mxCell id="8DqQCMdmOc6HaifYVGUy-5" parent="8DqQCMdmOc6HaifYVGUy-48" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;div&gt;🔍1. Was bedeutet mysqli_connect_error()?&lt;/div&gt;&lt;div&gt;mysqli_connect_error() gibt dir die Fehlermeldung der letzten fehlgeschlagenen MySQLi‑Verbindung zurück.&lt;/div&gt;&lt;div&gt;Beispiel:&lt;/div&gt;&lt;div&gt;&lt;div&gt;$conn = mysqli_connect(&quot;localhost&quot;, &quot;user&quot;, &quot;pass&quot;, &quot;db&quot;);&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;if (!$conn) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; echo &quot;Fehler: &quot; . mysqli_connect_error();&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/div&gt;&lt;div&gt;Das ist nützlich, wenn die Verbindung scheitert – z. B. falsches Passwort, falscher Host, Datenbank existiert nicht.&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="690" x="10" y="40" as="geometry" />
        </mxCell>
        <mxCell id="8DqQCMdmOc6HaifYVGUy-6" parent="8DqQCMdmOc6HaifYVGUy-48" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="🧩 2.&amp;nbsp;drei MySQL‑Arten in PHP" vertex="1">
          <mxGeometry height="230" width="690" x="10" y="195" as="geometry" />
