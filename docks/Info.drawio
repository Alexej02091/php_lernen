        <mxCell id="pKHLCEEhMPk__EJ80ix6-4" parent="pKHLCEEhMPk__EJ80ix6-15" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;1️⃣ Frontend sendet Request&lt;/div&gt;&lt;div&gt;Beispiel in React:&lt;/div&gt;&lt;div&gt;&lt;div&gt;axios.post(&quot;/api/login&quot;, { email, password })&lt;/div&gt;&lt;div&gt;&amp;nbsp; .then(res =&amp;gt; console.log(res.data));&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="240" x="310" y="10" as="geometry" />
        </mxCell>
        <mxCell id="pKHLCEEhMPk__EJ80ix6-5" parent="pKHLCEEhMPk__EJ80ix6-15" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;2️⃣ Backend empfängt Request und verarbeitet ihn&lt;/div&gt;&lt;div&gt;z. B. in deinem AuthController.&lt;/div&gt;" vertex="1">
          <mxGeometry height="40" width="290" x="310" y="100" as="geometry" />
