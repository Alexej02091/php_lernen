        <mxCell id="pNpbD_h_Uhzwr7Gy-MNP-2" parent="BuUvHkD3C2r66v8NpPr0-3" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="&lt;div style=&quot;color: rgb(204, 204, 204); background-color: rgb(31, 31, 31); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; line-height: 19px; white-space: pre;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;font&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: rgb(220, 220, 170);&quot;&gt;useEffect&lt;/span&gt;(() &lt;span style=&quot;color: rgb(86, 156, 214);&quot;&gt;=&amp;gt;&lt;/span&gt; {&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #4fc1ff;&quot;&gt;axios&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;get&lt;/span&gt;(&lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;http://localhost:3001/biersortiment&#39;&lt;/span&gt;)&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;span style=&quot;color: #dcdcaa;&quot;&gt;then&lt;/span&gt;(&lt;span style=&quot;color: #9cdcfe;&quot;&gt;response&lt;/span&gt; &lt;span style=&quot;color: #569cd6;&quot;&gt;=&amp;gt;&lt;/span&gt; {&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #dcdcaa;&quot;&gt;setUsers&lt;/span&gt;(&lt;span style=&quot;color: #9cdcfe;&quot;&gt;response&lt;/span&gt;.&lt;span style=&quot;color: #9cdcfe;&quot;&gt;data&lt;/span&gt;);&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; })&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;span style=&quot;color: #dcdcaa;&quot;&gt;catch&lt;/span&gt;(&lt;span style=&quot;color: #9cdcfe;&quot;&gt;error&lt;/span&gt; &lt;span style=&quot;color: #569cd6;&quot;&gt;=&amp;gt;&lt;/span&gt; {&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;color: #9cdcfe;&quot;&gt;console&lt;/span&gt;.&lt;span style=&quot;color: #dcdcaa;&quot;&gt;error&lt;/span&gt;(&lt;span style=&quot;color: #ce9178;&quot;&gt;&#39;There was an error fetching the users!&#39;&lt;/span&gt;, &lt;span style=&quot;color: #9cdcfe;&quot;&gt;error&lt;/span&gt;);&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; });&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font&gt;&amp;nbsp; &amp;nbsp; }, []);&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="480" x="136" y="340" as="geometry" />
        </mxCell>
        <mxCell id="pNpbD_h_Uhzwr7Gy-MNP-3" parent="BuUvHkD3C2r66v8NpPr0-3" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="&lt;b&gt;useEffect&lt;/b&gt; ist ein React-Hook. Er erlaubt, Nebenwirkungen (Side Effects) auszuführen" vertex="1">
