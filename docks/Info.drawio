          </mxGeometry>
        </mxCell>
        <mxCell id="KFwVIHRTOtqEWXRbHIaX-24" parent="KFwVIHRTOtqEWXRbHIaX-51" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="🗄️ &lt;strong&gt;Repository&lt;/strong&gt;&lt;div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Was es ist:&amp;nbsp;&amp;nbsp;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Das Repository ist die Datenzugriffsschicht.&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Es spricht mit der Datenbank und gibt Models zurück.&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Beispiel:&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;div&gt;class UserRepository {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public function findByEmail($email) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $stmt = $this-&amp;gt;db-&amp;gt;prepare(&quot;SELECT * FROM users WHERE email = ?&quot;);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $stmt-&amp;gt;execute([$email]);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; return $stmt-&amp;gt;fetchObject(User::class);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;strong&gt;Kurz gesagt:&lt;/strong&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp;Repository = „Wie komme ich an Daten?“&lt;/div&gt;&lt;/b&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="250" width="530" x="220" y="870" as="geometry" />
        </mxCell>
        <mxCell id="KFwVIHRTOtqEWXRbHIaX-25" edge="1" parent="KFwVIHRTOtqEWXRbHIaX-51" source="KFwVIHRTOtqEWXRbHIaX-22" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="KFwVIHRTOtqEWXRbHIaX-24" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
