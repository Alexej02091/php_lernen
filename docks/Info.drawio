        <mxCell id="Whp2AbG9F2wWwhStgsQD-8" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;fontSize=10;" value="&lt;div&gt;&lt;h2 style=&quot;margin-top: 0px; margin-bottom: 0px;&quot;&gt;&lt;code&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;&amp;lt;?php&lt;/font&gt;&lt;/code&gt;&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Das öffnet den PHP‑Interpreter. Alles danach wird als PHP‑Code ausgeführt.&lt;/span&gt;&lt;/p&gt;&lt;/div&gt;" vertex="1">
