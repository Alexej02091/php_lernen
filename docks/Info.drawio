        <mxCell id="KFwVIHRTOtqEWXRbHIaX-12" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;b&gt;Was ist die &lt;code&gt;composer.json&lt;/code&gt;?&lt;/b&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Das ist deine Konfigurationsdatei für Composer.&lt;/div&gt;&lt;div&gt;Darin steht:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;wie dein Projekt heißt&lt;/li&gt;&lt;li&gt;welche PHP‑Version du brauchst&lt;/li&gt;&lt;li&gt;welche Libraries du installierst&lt;/li&gt;&lt;li&gt;wie dein Autoloading funktioniert (PSR‑4)&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Ohne composer.json weiß Composer nicht, was dein Projekt tun soll.&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Warum musst du sie selbst erstellen?&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Weil du entscheidest:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;wie dein Namespace heißt (App\\)&lt;/li&gt;&lt;li&gt;wo dein Code liegt (src/App/)&lt;/li&gt;&lt;li&gt;welche Libraries du brauchst (require)&lt;/li&gt;&lt;li&gt;welche PHP‑Version du unterstützt&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Composer kann das nicht erraten.&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Wie hängt das mit &lt;code&gt;vendor/autoload.php&lt;/code&gt; zusammen?&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;div style=&quot;&quot;&gt;&lt;ol&gt;&lt;li&gt;&lt;b&gt;Du erstellst composer.json.&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Composer liest sie.&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Composer erzeugt daraus:&lt;/b&gt;&lt;/li&gt;&lt;ul&gt;&lt;li&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;vendor/&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;vendor/autoload.php&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Autoload‑Mapping&lt;/b&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/ol&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Ohne composer.json → kein Autoloader.&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="490" width="330" x="-180" y="1180" as="geometry" />
        </mxCell>
        <mxCell id="KFwVIHRTOtqEWXRbHIaX-13" edge="1" parent="1" source="KFwVIHRTOtqEWXRbHIaX-9" style="endArrow=classic;html=1;rounded=0;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="KFwVIHRTOtqEWXRbHIaX-12" value="">
