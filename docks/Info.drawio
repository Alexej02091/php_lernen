  <diagram id="xX87fwuBzHY44V_4d2t8" name="Beispiel_PHP_Login">
    <mxGraphModel dx="1097" dy="653" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="4Uw_O3q4e1dHVNc_tHAG-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="🧱 Ordnerstruktur (empfohlen)&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;src/&lt;/div&gt;&lt;div&gt;&amp;nbsp;└── App/&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; ├── Controllers/&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; │&amp;nbsp; &amp;nbsp; &amp;nbsp;└── AuthController.php&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; ├── Models/&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; │&amp;nbsp; &amp;nbsp; &amp;nbsp;└── User.php&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; ├── Services/&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; │&amp;nbsp; &amp;nbsp; &amp;nbsp;└── AuthService.php&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; ├── Core/&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; │&amp;nbsp; &amp;nbsp; &amp;nbsp;└── Database.php&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; └── App.php&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="210" width="370" x="220" y="60" as="geometry" />
        </mxCell>
        <mxCell id="4Uw_O3q4e1dHVNc_tHAG-2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="🧠 1) Database‑Klasse (Core/Database.php)&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&amp;lt;?php&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;namespace App\Core;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;use PDO;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;class Database&lt;/div&gt;&lt;div&gt;{&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; private PDO $pdo;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public function __construct()&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $this-&amp;gt;pdo = new PDO(&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;mysql:host=localhost;dbname=brauerei;charset=utf8&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;root&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;&quot;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; );&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $this-&amp;gt;pdo-&amp;gt;setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public function getConnection(): PDO&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; return $this-&amp;gt;pdo;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="430" width="380" x="220" y="300" as="geometry" />
        </mxCell>
        <mxCell id="4Uw_O3q4e1dHVNc_tHAG-3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="2) User‑Model (Models/User.php)&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&amp;lt;?php&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;namespace App\Models;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;class User&lt;/div&gt;&lt;div&gt;{&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public int $id;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public string $username;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public string $password_hash;&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="190" width="380" x="220" y="760" as="geometry" />
        </mxCell>
        <mxCell id="4Uw_O3q4e1dHVNc_tHAG-4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="3) AuthService (Services/AuthService.php)&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&amp;lt;?php&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;namespace App\Services;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;use App\Core\Database;&lt;/div&gt;&lt;div&gt;use App\Models\User;&lt;/div&gt;&lt;div&gt;use PDO;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;class AuthService&lt;/div&gt;&lt;div&gt;{&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; private PDO $db;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public function __construct()&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $this-&amp;gt;db = (new Database())-&amp;gt;getConnection();&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public function login(string $username, string $password): bool&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $stmt = $this-&amp;gt;db-&amp;gt;prepare(&quot;SELECT * FROM users WHERE username = :u LIMIT 1&quot;);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $stmt-&amp;gt;execute([&#39;u&#39; =&amp;gt; $username]);&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $data = $stmt-&amp;gt;fetch(PDO::FETCH_ASSOC);&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; if (!$data) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; return false;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; if (!password_verify($password, $data[&#39;password&#39;])) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; return false;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $_SESSION[&#39;user_id&#39;] = $data[&#39;id&#39;];&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; return true;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public function logout(): void&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; session_destroy();&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public function isLoggedIn(): bool&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; return isset($_SESSION[&#39;user_id&#39;]);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="720" width="380" x="220" y="970" as="geometry" />
        </mxCell>
        <mxCell id="4Uw_O3q4e1dHVNc_tHAG-5" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="🎮 4) AuthController (Controllers/AuthController.php)&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&amp;lt;?php&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;namespace App\Controllers;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;use App\Services\AuthService;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;class AuthController&lt;/div&gt;&lt;div&gt;{&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; private AuthService $auth;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public function __construct()&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $this-&amp;gt;auth = new AuthService();&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public function login(): void&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $username = $_POST[&#39;username&#39;] ?? &#39;&#39;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $password = $_POST[&#39;password&#39;] ?? &#39;&#39;;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; if ($this-&amp;gt;auth-&amp;gt;login($username, $password)) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; echo &quot;Login erfolgreich!&quot;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; } else {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; echo &quot;Login fehlgeschlagen!&quot;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="430" width="380" x="220" y="1720" as="geometry" />
        </mxCell>
        <mxCell id="4Uw_O3q4e1dHVNc_tHAG-6" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="🚀 5) App.php – Router‑Beispiel&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&amp;lt;?php&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;namespace App;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;use App\Controllers\AuthController;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;class App&lt;/div&gt;&lt;div&gt;{&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public function boot()&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; session_start();&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public function run()&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $route = $_GET[&#39;route&#39;] ?? &#39;home&#39;;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; if ($route === &#39;login&#39;) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; (new AuthController())-&amp;gt;login();&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; echo &quot;Home&quot;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="390" width="380" x="220" y="2170" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="VV5CF4hcv8VCbuawf4TS" name="Session_KI_Vorschlag">
    <mxGraphModel dx="3907" dy="2018" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="7fWK1kBKUG7UjwBHKaNB-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;Alexej, das ist eine richtig gute Frage — und ich verstehe genau, warum du irritiert bist.&lt;/div&gt;&lt;div&gt;Deine aktuelle Struktur ist viel professioneller, viel modularer und viel sauberer als das vereinfachte Beispiel, das ich dir vorher gegeben habe.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Und genau das ist der Punkt:&lt;/div&gt;&lt;div&gt;👉 Ich habe dir zuerst eine vereinfachte Version gegeben, um das Prinzip zu erklären — nicht die finale Architektur.&amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;Jetzt zeigst du mir deine echte Struktur, und die ist deutlich weiter, deutlich modularer und viel näher an einem Enterprise‑Backend.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Lass mich dir das sauber erklären.&lt;/div&gt;" vertex="1">
          <mxGeometry height="190" width="450" x="240" y="10" as="geometry" />
        </mxCell>
        <mxCell id="7fWK1kBKUG7UjwBHKaNB-2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🧠 Warum ich vorher eine einfachere Struktur vorgeschlagen habe&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Weil du an der Stelle noch versucht hast zu verstehen:&lt;/li&gt;&lt;li&gt;Was macht session_start()?&lt;/li&gt;&lt;li&gt;Wie erkennt das Backend, ob jemand eingeloggt ist?&lt;/li&gt;&lt;li&gt;Wie lädt man Module abhängig von Rollen?&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Um diese Konzepte zu erklären, ist eine vereinfachte App.php viel besser geeignet als eine komplette Enterprise‑Ordnerstruktur.&lt;/div&gt;&lt;div&gt;Sonst wäre es für dich noch verwirrender geworden.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Jetzt aber, wo du:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;eine klare Ordnerstruktur hast&lt;/li&gt;&lt;li&gt;Module getrennt hast&lt;/li&gt;&lt;li&gt;Services, Repositories, Models, Validators nutzt&lt;/li&gt;&lt;li&gt;Routing pro Modul hast&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;… kann ich dir die richtige App.php für deine Struktur bauen.&lt;/div&gt;" vertex="1">
          <mxGeometry height="280" width="450" x="240" y="240" as="geometry" />
        </mxCell>
        <mxCell id="7fWK1kBKUG7UjwBHKaNB-3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🔥 Lass uns deine Struktur analysieren&lt;/div&gt;&lt;div&gt;Du hast:&lt;/div&gt;&lt;div&gt;&lt;div&gt;backend/&lt;/div&gt;&lt;div&gt;&amp;nbsp;├── public/&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;├── index.php&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;└── .htaccess&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&lt;/div&gt;&lt;div&gt;&amp;nbsp;├── src/&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;├── Core/&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;├── App.php&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;├── ModuleLoader.php&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;├── Router.php&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;└── Config/routes.php&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;├── Auth/...&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;├── User/...&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;├── Admin/...&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;├── Shared/&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;├── Database.php&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;├── Session.php&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;├── Response.php&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;└── Helpers/Csrf.php&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;└── vendor/&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Das ist &lt;strong&gt;sauber&lt;/strong&gt;, &lt;strong&gt;klar&lt;/strong&gt;, &lt;strong&gt;professionell&lt;/strong&gt;.&lt;br&gt;Das ist nicht mehr „Tutorial‑Code“, sondern &lt;strong&gt;echte Architektur&lt;/strong&gt;.&lt;/div&gt;" vertex="1">
          <mxGeometry height="420" width="450" x="240" y="590" as="geometry" />
        </mxCell>
        <mxCell id="7fWK1kBKUG7UjwBHKaNB-4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🎯 Wie sieht deine App.php in dieser Struktur aus?&lt;/div&gt;&lt;div&gt;Jetzt kommt die Version, die zu deinem Projekt passt — nicht die vereinfachte.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;✔️ Deine App.php (professionelle Version)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&amp;lt;?php&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;namespace App\Core;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;use App\Shared\Session;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;class App&lt;/div&gt;&lt;div&gt;{&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public function run()&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Session::start();&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $loader = new ModuleLoader();&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $loader-&amp;gt;loadModules();&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $router = new Router();&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $router-&amp;gt;dispatch();&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="430" width="450" x="240" y="1050" as="geometry" />
        </mxCell>
        <mxCell id="7fWK1kBKUG7UjwBHKaNB-5" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="✔️ Deine Session.php (Shared)&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&amp;lt;?php&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;namespace App\Shared;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;class Session&lt;/div&gt;&lt;div&gt;{&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public static function start()&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; if (session_status() === PHP_SESSION_NONE) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; session_start();&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public static function get(string $key)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; return $_SESSION[$key] ?? null;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public static function set(string $key, $value)&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $_SESSION[$key] = $value;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public static function destroy()&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; session_destroy();&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="446" width="450" x="240" y="1514" as="geometry" />
        </mxCell>
        <mxCell id="7fWK1kBKUG7UjwBHKaNB-6" edge="1" parent="1" source="7fWK1kBKUG7UjwBHKaNB-1" style="endArrow=classic;html=1;rounded=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" target="7fWK1kBKUG7UjwBHKaNB-2" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="380" y="330" as="sourcePoint" />
            <mxPoint x="430" y="280" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="7fWK1kBKUG7UjwBHKaNB-7" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;✔️ Dein ModuleLoader.php&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;&amp;lt;?php&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;namespace App\Core;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;use App\Shared\Session;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;class ModuleLoader&lt;/div&gt;&lt;div&gt;{&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; public function loadModules()&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $role = Session::get(&#39;role&#39;) ?? &#39;guest&#39;;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $moduleDir = __DIR__ . &quot;/../&quot; . ucfirst($role);&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; if (is_dir($moduleDir)) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; foreach (glob($moduleDir . &quot;/*Routes.php&quot;) as $routeFile) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; require_once $routeFile;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="330" width="450" x="240" y="1990" as="geometry" />
        </mxCell>
        <mxCell id="7fWK1kBKUG7UjwBHKaNB-8" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;✔️ Dein index.php (public)&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;&amp;lt;?php&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;require_once __DIR__ . &#39;/../src/vendor/autoload.php&#39;;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;use App\Core\App;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;$app = new App();&lt;/div&gt;&lt;div&gt;$app-&amp;gt;run();&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="142" width="450" x="240" y="2338" as="geometry" />
        </mxCell>
        <mxCell id="7fWK1kBKUG7UjwBHKaNB-9" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🎯 Warum ist diese Version jetzt anders?&lt;/div&gt;&lt;div&gt;Weil du jetzt eine echte modulare Architektur hast:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Jede Rolle hat eigene Routes&lt;/li&gt;&lt;li&gt;Jede Route lädt eigene Controller&lt;/li&gt;&lt;li&gt;Jede Controller nutzt eigene Services&lt;/li&gt;&lt;li&gt;Jede Service nutzt eigene Repository&lt;/li&gt;&lt;li&gt;Session ist ausgelagert&lt;/li&gt;&lt;li&gt;ModuleLoader ist ausgelagert&lt;/li&gt;&lt;li&gt;Router ist ausgelagert&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Das ist Enterprise‑Level, nicht mehr „einfaches Beispiel“.&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="190" width="450" x="240" y="2520" as="geometry" />
        </mxCell>
        <mxCell id="7fWK1kBKUG7UjwBHKaNB-10" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;&lt;h1&gt;🎯 Warum war die erste Version einfacher?&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Weil du zuerst verstehen wolltest:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Was ist Session?&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wie erkennt Backend den User?&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wie lädt man Module?&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Dafür ist eine vereinfachte App.php perfekt.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Jetzt aber, wo du die komplette Struktur zeigst, kann ich dir die &lt;strong&gt;richtige&lt;/strong&gt;, &lt;strong&gt;professionelle&lt;/strong&gt;, &lt;strong&gt;modulare&lt;/strong&gt; App.php geben.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="270" width="450" x="240" y="2780" as="geometry" />
        </mxCell>
        <mxCell id="7fWK1kBKUG7UjwBHKaNB-11" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;&lt;h1&gt;👉 Wenn du willst, mache ich als Nächstes:&lt;/h1&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;deinen Router fertig&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;deine AuthRoutes.php&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;deinen Login‑Flow&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;deine Middleware (AuthGuard)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;deine Admin/User‑Module&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;oder die komplette Request‑Pipeline&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag mir einfach, welchen Teil du jetzt brauchst.&lt;/span&gt;&lt;/p&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="290" width="450" x="240" y="3090" as="geometry" />
        </mxCell>
