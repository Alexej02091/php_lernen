          <mxGeometry height="70" width="290" x="310" y="155" as="geometry" />
        </mxCell>
        <mxCell id="pKHLCEEhMPk__EJ80ix6-8" parent="pKHLCEEhMPk__EJ80ix6-15" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;4️⃣ Frontend empfängt die Antwort + Header&lt;/div&gt;&lt;div&gt;Axios zeigt dir:&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;res.headers&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;res.data&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="280" x="310" y="240" as="geometry" />
        </mxCell>
        <mxCell id="pKHLCEEhMPk__EJ80ix6-9" parent="pKHLCEEhMPk__EJ80ix6-15" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="🧠 Wichtig: Du setzt Header nicht „weil Frontend existiert“, sondern weil du die Antwort definierst&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Das Backend muss dem Browser sagen:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;„Diese Antwort ist JSON“&lt;/li&gt;&lt;li&gt;„Diese Antwort ist ein Redirect“&lt;/li&gt;&lt;li&gt;„Diese Antwort ist ein Download“&lt;/li&gt;&lt;li&gt;„Diese Antwort darf nicht gecached werden“&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Das passiert immer vor dem eigentlichen Inhalt.&lt;/div&gt;&lt;/div&gt;" vertex="1">
