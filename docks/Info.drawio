        <mxCell id="pKHLCEEhMPk__EJ80ix6-88" parent="wo0p1ZfNdt3Z2teXgPPR-10" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;fontSize=16;" vertex="1">
