        </mxCell>
        <mxCell id="w7DwOR1FbQZn8UWmJBvV-3" parent="w7DwOR1FbQZn8UWmJBvV-58" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;div style=&quot;font-weight: bold;&quot;&gt;&lt;div&gt;🧱 Wie modelliert man einen Admin in PHP‑OOP richtig?&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Alexej, das ist eine klassische Architekturfrage – und genau die Art von Problem, bei dem sauberes Design später enorm viel Chaos verhindert.&lt;/div&gt;&lt;div&gt;Du denkst absolut in die richtige Richtung, aber lass uns das sauber strukturieren.&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="490" x="60" as="geometry" />
        </mxCell>
        <mxCell id="w7DwOR1FbQZn8UWmJBvV-4" parent="w7DwOR1FbQZn8UWmJBvV-58" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;div&gt;&lt;div style=&quot;font-weight: bold;&quot;&gt;🎯 Grundidee: Ein Admin ist ein User – mit zusätzlichen Fähigkeiten&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Ein Admin ist kein „UserVerwalten“ oder „WohnungVerwalten“.&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Ein Admin führt diese Aktionen aus, aber er ist sie nicht.&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Darum wäre es falsch, so etwas zu machen:&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;div&gt;class UserVerwalten {}&lt;/div&gt;&lt;div&gt;class WohnungVerwalten {}&lt;/div&gt;&lt;div&gt;class ZimmerVerwalten {}&lt;/div&gt;&lt;div&gt;class Admin extends UserVerwalten {}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Das ergibt semantisch keinen Sinn.&lt;/div&gt;&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="190" width="490" x="60" y="110" as="geometry" />
        </mxCell>
        <mxCell id="w7DwOR1FbQZn8UWmJBvV-5" parent="w7DwOR1FbQZn8UWmJBvV-58" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;div&gt;&lt;div style=&quot;font-weight: bold;&quot;&gt;🧠 Saubere OOP‑Architektur: Rollen + Services&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;font-weight: bold;&quot;&gt;✔️ 1. Admin ist eine Unterklasse von User&lt;/div&gt;&lt;div style=&quot;font-weight: bold;&quot;&gt;Denn ein Admin ist ein User, nur mit mehr Rechten.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;class User {&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; protected string $name;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; protected string $role = &#39;user&#39;;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;}&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;class Admin extends User {&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; protected string $role = &#39;admin&#39;;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;}&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;font-weight: bold;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="490" x="60" y="325" as="geometry" />
        </mxCell>
        <mxCell id="w7DwOR1FbQZn8UWmJBvV-6" parent="w7DwOR1FbQZn8UWmJBvV-58" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;div&gt;&lt;div style=&quot;font-weight: bold;&quot;&gt;✔️ 2. Die Aktionen (User verwalten, Wohnungen verwalten, Zimmer verwalten) gehören NICHT in die Admin‑Klasse&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Warum?&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;ul&gt;&lt;li&gt;&lt;b&gt;Das sind Funktionen, keine Eigenschaften des Admins&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Sie ändern sich unabhängig vom Admin&lt;/b&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Sie können auch von anderen Rollen genutzt werden (z. B. Hausmeister verwaltet Zimmer)&lt;/b&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Darum gehören sie in Service‑Klassen:&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;class UserService {&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; public function createUser() {}&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; public function deleteUser() {}&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;}&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;class WohnungService {&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; public function createWohnung() {}&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;}&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;class ZimmerService {&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; public function createZimmer() {}&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;}&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;font-weight: bold;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="325" width="490" x="60" y="520" as="geometry" />
        </mxCell>
        <mxCell id="w7DwOR1FbQZn8UWmJBvV-7" parent="w7DwOR1FbQZn8UWmJBvV-58" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;div&gt;&lt;div style=&quot;font-weight: bold;&quot;&gt;🧩 3. Admin nutzt diese Services&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;Der Admin nutzt die Services, er ist sie nicht.&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;class Admin extends User {&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; private UserService $userService;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; private WohnungService $wohnungService;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; private ZimmerService $zimmerService;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; public function __construct() {&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $this-&amp;gt;userService = new UserService();&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $this-&amp;gt;wohnungService = new WohnungService();&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $this-&amp;gt;zimmerService = new ZimmerService();&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; }&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; public function createUser() {&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; $this-&amp;gt;userService-&amp;gt;createUser();&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; }&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;}&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;font-weight: bold;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="270" width="490" x="60" y="875" as="geometry" />
        </mxCell>
        <mxCell id="w7DwOR1FbQZn8UWmJBvV-8" parent="w7DwOR1FbQZn8UWmJBvV-58" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=5;" value="&lt;div&gt;&lt;div style=&quot;font-weight: bold;&quot;&gt;🏛️ 4. Noch besser: Admin hat nur Rechte – nicht die Logik&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;p style=&quot;font-weight: bold;&quot;&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Das ist die modernste Architektur:&lt;/span&gt;&lt;/p&gt;&lt;h3 style=&quot;font-weight: bold;&quot;&gt;🔹 &lt;strong&gt;User / Admin = Rollen&lt;/strong&gt;&lt;/h3&gt;&lt;h3 style=&quot;font-weight: bold;&quot;&gt;🔹 &lt;strong&gt;Services = Logik&lt;/strong&gt;&lt;/h3&gt;&lt;h3 style=&quot;font-weight: bold;&quot;&gt;🔹 &lt;strong&gt;Controller prüft: Darf der Admin das?&lt;/strong&gt;&lt;/h3&gt;&lt;div style=&quot;font-weight: bold;&quot;&gt;Beispiel:&lt;strong&gt;&lt;/strong&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;if ($currentUser-&amp;gt;role === &#39;admin&#39;) {&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; $userService-&amp;gt;createUser();&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;}&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;font-weight: bold;&quot;&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;So bleibt dein System:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;flexibel&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;testbar&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;erweiterbar&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;sauber getrennt&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="350" width="490" x="60" y="1165" as="geometry" />
        </mxCell>
