        <mxCell id="wGHetAYyMtZg8utDns9d-53" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="🔧 &lt;strong&gt;Wie wird PDO erzeugt?&lt;/strong&gt;&lt;div&gt;Hier:&lt;strong&gt;&lt;/strong&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;$this-&amp;gt;pdo = new PDO(&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &quot;mysql:host=localhost;dbname=brauerei;charset=utf8&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &quot;root&quot;,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &quot;&quot;&lt;/div&gt;&lt;div&gt;);&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Das bedeutet:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Stelle eine Verbindung zu MySQL her&lt;/li&gt;&lt;li&gt;Datenbankname: brauerei&lt;/li&gt;&lt;li&gt;Benutzer: root&lt;/li&gt;&lt;li&gt;Passwort: &quot;&quot; (leer)&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="450" x="-1710" y="630" as="geometry" />
        </mxCell>
        <mxCell id="wGHetAYyMtZg8utDns9d-54" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="🔥 &lt;strong&gt;Warum setzt du diesen Modus?&lt;/strong&gt;&lt;div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;$this-&amp;gt;pdo-&amp;gt;setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;font-weight: bold;&quot;&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Das bedeutet:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;👉 Wenn ein Fehler passiert, wirft PDO eine Exception&lt;br/&gt;→ viel besser als stilles Scheitern&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="450" x="-1710" y="870" as="geometry" />
        </mxCell>
        <mxCell id="wGHetAYyMtZg8utDns9d-55" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="🧩 &lt;strong&gt;Wie benutzt man PDO später?&lt;/strong&gt;&lt;div&gt;Beispiel aus deinem Login‑Flow:&lt;strong&gt;&lt;/strong&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;$stmt = $db-&amp;gt;prepare(&quot;SELECT * FROM users WHERE name = :name LIMIT 1&quot;);&lt;/div&gt;&lt;div&gt;$stmt-&amp;gt;execute([&#39;name&#39; =&amp;gt; $name]);&lt;/div&gt;&lt;div&gt;$user = $stmt-&amp;gt;fetch();&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Hier passiert:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;$db ist dein PDO‑Objekt&lt;/li&gt;&lt;li&gt;prepare() erzeugt ein Prepared Statement&lt;/li&gt;&lt;li&gt;execute() setzt Parameter ein&lt;/li&gt;&lt;li&gt;fetch() holt die Datenbankzeile&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="450" x="-1710" y="1020" as="geometry" />
        </mxCell>
        <mxCell id="wGHetAYyMtZg8utDns9d-56" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="🎉 Kurz gesagt&lt;div&gt;&lt;div&gt;PDO ist die moderne, sichere Art, in PHP mit Datenbanken zu arbeiten.&lt;/div&gt;&lt;div&gt;Es ist:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;ein Datenbank‑Objekt&lt;/li&gt;&lt;li&gt;ein Sicherheits‑Tool&lt;/li&gt;&lt;li&gt;ein SQL‑Interface&lt;/li&gt;&lt;li&gt;ein Standard in professionellen PHP‑Projekten&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Und du benutzt es absolut richtig.&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="450" x="-1710" y="1210" as="geometry" />
        </mxCell>
        <mxCell id="wGHetAYyMtZg8utDns9d-57" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;Wenn du willst, zeige ich dir als Nächstes:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;wie Database::getConnection() überall sauber genutzt wird&lt;/li&gt;&lt;li&gt;wie du Fehler abfängst&lt;/li&gt;&lt;li&gt;wie du Transaktionen machst&lt;/li&gt;&lt;li&gt;oder wie du ein Repository‑Pattern perfekt mit PDO kombinierst&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Sag einfach, wohin wir weitergehen.&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="450" x="-1710" y="1390" as="geometry" />
        </mxCell>
        <mxCell id="wGHetAYyMtZg8utDns9d-58" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="" vertex="1">
          <mxGeometry height="190" width="450" x="-1710" y="1840" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
