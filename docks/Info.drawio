        </mxCell>
        <mxCell id="iud6hWaGE5kNCWCGpW4J-5" parent="_NgpSxgU6XjmauKNE8cU-3" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=16;fontSize=14;" value="Eine &lt;b&gt;Komponente&lt;/b&gt; in Ract ist ein &lt;b&gt;wiederverwendbares Bauteil&lt;/b&gt;, das ein Stück UI beschreibt" vertex="1">
          <mxGeometry height="60" width="370" x="221" y="60" as="geometry" />
        </mxCell>
        <mxCell id="iud6hWaGE5kNCWCGpW4J-6" parent="_NgpSxgU6XjmauKNE8cU-3" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=13;" value="Eine Komponente ist:&lt;div&gt;&lt;ul&gt;&lt;li&gt;eine JavaScript-Funktion, die JSX zurückgibt&lt;/li&gt;&lt;li&gt;ein eigenständiges UI-Element (z.B. Button, Formular, Nacbar)&lt;/li&gt;&lt;li&gt;wiederverwendbar und isoliert&lt;/li&gt;&lt;li&gt;zustandsbasiert (kann State haben) oder rein (nur Props)&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="370" x="221" y="150" as="geometry" />
        </mxCell>
        <mxCell id="aR1TKIMmTiw1zpOH1DMq-1" parent="_NgpSxgU6XjmauKNE8cU-3" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="const &lt;font style=&quot;color: rgb(178, 102, 255);&quot;&gt;Biersortiment &lt;/font&gt;=() =&amp;gt; {...}&amp;nbsp;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Keine Variable sondern der Name einer Komponente&lt;/b&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="244" x="251" y="690" as="geometry" />
        </mxCell>
        <mxCell id="aR1TKIMmTiw1zpOH1DMq-2" parent="_NgpSxgU6XjmauKNE8cU-3" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=4;" value="&lt;div&gt;&lt;b&gt;Eine einfache Komponente&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 127, 255);&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 127, 255);&quot;&gt;function &lt;/font&gt;&lt;font style=&quot;color: rgb(255, 102, 255);&quot;&gt;Welcome&lt;/font&gt;() {&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;font style=&quot;color: rgb(0, 127, 255);&quot;&gt;return &lt;/font&gt;&amp;lt;&lt;font style=&quot;color: rgb(0, 127, 255);&quot;&gt;h1&lt;/font&gt;&amp;gt;Hallo Alexej!&amp;lt;/&lt;font style=&quot;color: rgb(0, 127, 255);&quot;&gt;h1&lt;/font&gt;&amp;gt;;&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="216" x="285" y="320" as="geometry" />
        </mxCell>
        <mxCell id="aR1TKIMmTiw1zpOH1DMq-4" parent="_NgpSxgU6XjmauKNE8cU-3" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=4;" value="&lt;div&gt;&lt;b&gt;Function Components (heute Standard)&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 127, 255);&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 127, 255);&quot;&gt;function &lt;/font&gt;&lt;font style=&quot;color: rgb(255, 102, 255);&quot;&gt;Button&lt;/font&gt;({ text }) {&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;font style=&quot;color: rgb(0, 127, 255);&quot;&gt;return &lt;/font&gt;&amp;lt;&lt;font color=&quot;#007fff&quot;&gt;button&lt;/font&gt;&amp;gt;{text}&amp;lt;/&lt;font color=&quot;#007fff&quot;&gt;button&lt;/font&gt;&amp;gt;;&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Class Components (älter, kaum noch genutzt)&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 127, 255);&quot;&gt;class&amp;nbsp;&lt;/font&gt;&lt;font style=&quot;color: rgb(255, 102, 255);&quot;&gt;Button &lt;/font&gt;&lt;font style=&quot;color: rgb(0, 127, 255);&quot;&gt;extends &lt;/font&gt;&lt;font style=&quot;color: rgb(255, 102, 255);&quot;&gt;React.Component&amp;nbsp;&lt;/font&gt;{&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;font style=&quot;color: rgb(255, 102, 255);&quot;&gt;render&lt;/font&gt;()&amp;nbsp;{&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;&lt;font style=&quot;color: rgb(0, 127, 255);&quot;&gt;return&amp;nbsp;&lt;/font&gt;&amp;lt;&lt;font color=&quot;#007fff&quot;&gt;button&lt;/font&gt;&amp;gt;{this.props.text}&amp;lt;/&lt;font color=&quot;#007fff&quot;&gt;button&lt;/font&gt;&amp;gt;;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;}&lt;br&gt;&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="210" width="290" x="241" y="440" as="geometry" />
        </mxCell>
        <mxCell id="ci9PW1Qkv8DYoqxgiI6i-21" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="1130" width="790" x="19" y="-1149" as="geometry" />
        </mxCell>
        <mxCell id="_NgpSxgU6XjmauKNE8cU-4" parent="ci9PW1Qkv8DYoqxgiI6i-21" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;" value="Props" vertex="1">
          <mxGeometry height="1130" width="790" as="geometry" />
        </mxCell>
        <mxCell id="ci9PW1Qkv8DYoqxgiI6i-1" parent="ci9PW1Qkv8DYoqxgiI6i-21" style="html=1;whiteSpace=wrap;align=left;verticalAlign=top;" value="&lt;b&gt;Props (Properties)&lt;/b&gt; sind Daten, die eine Komponente von außen bekommt.&lt;div&gt;Sie sind &lt;b&gt;Eingabewerte für eine Komponente&lt;/b&gt; - ähnlich wie &lt;b&gt;Parameter bei einer Funktion&lt;/b&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="40" width="501" x="139" y="20" as="geometry" />
        </mxCell>
        <mxCell id="ci9PW1Qkv8DYoqxgiI6i-2" parent="ci9PW1Qkv8DYoqxgiI6i-21" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#FF0000;" value="&lt;b&gt;Props = Daten von außen&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="150" x="620" y="80" as="geometry" />
        </mxCell>
        <mxCell id="ci9PW1Qkv8DYoqxgiI6i-3" parent="ci9PW1Qkv8DYoqxgiI6i-21" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" value="Props ermöglichen:&lt;div&gt;&lt;ul&gt;&lt;li&gt;Wiederverwendbarkeit von Komponenten&lt;/li&gt;&lt;li&gt;Konfiguration von Komponenten&lt;/li&gt;&lt;li&gt;&lt;b&gt;Kommunikation von Eltern- zu Kind-Komponenten&lt;/b&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="340" x="50" y="80" as="geometry" />
        </mxCell>
        <mxCell id="ci9PW1Qkv8DYoqxgiI6i-4" parent="ci9PW1Qkv8DYoqxgiI6i-21" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=3;fontSize=12;verticalAlign=top;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Elternkomponente:&lt;/font&gt;&lt;/b&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 127, 255);&quot;&gt;funktion &lt;/font&gt;&lt;font style=&quot;color: rgb(255, 102, 255);&quot;&gt;App&lt;/font&gt;() {&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;font style=&quot;color: rgb(0, 127, 255);&quot;&gt;return &lt;/font&gt;&amp;lt;&lt;font style=&quot;color: rgb(0, 127, 255);&quot;&gt;Bier &lt;/font&gt;&lt;font style=&quot;color: rgb(255, 128, 0);&quot;&gt;name&lt;/font&gt;=&lt;font style=&quot;color: rgb(0, 153, 0);&quot;&gt;&quot;Pils&quot;&lt;/font&gt; &lt;font style=&quot;color: rgb(255, 128, 0);&quot;&gt;alkohol&lt;/font&gt;=&lt;font style=&quot;color: rgb(0, 153, 0);&quot;&gt;{4.9}&lt;/font&gt; /&amp;gt;;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;}&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Kindkomponente:&lt;/font&gt;&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 127, 255));&quot;&gt;function &lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 102, 255));&quot;&gt;Bier&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;(&lt;b&gt;props&lt;/b&gt;) {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 127, 255));&quot;&gt;return &lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;(&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&amp;lt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 127, 255));&quot;&gt;div&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&amp;lt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 127, 255));&quot;&gt;h2&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;gt;{&lt;b&gt;props&lt;/b&gt;.&lt;b&g