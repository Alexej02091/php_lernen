          <mxGeometry height="320" width="610" as="geometry" />
        </mxCell>
        <mxCell id="pKHLCEEhMPk__EJ80ix6-2" parent="pKHLCEEhMPk__EJ80ix6-15" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="🧩 &lt;strong&gt;Wie läuft das technisch ab?&lt;/strong&gt;" vertex="1">
          <mxGeometry height="30" width="200" x="40" y="70" as="geometry" />
