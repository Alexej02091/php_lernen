        <mxCell id="KsfAjccjcwBvy7qC1BYC-3" parent="BuUvHkD3C2r66v8NpPr0-2" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="Eine Bibliothek ist ein Paket (meist aus npm), das bestimmte Funktionen oder UI-Komponenten bereitstellt, die im React-Projekt verwendet wird." vertex="1">
          <mxGeometry height="40" width="420" x="195" y="20" as="geometry" />
        </mxCell>
        <mxCell id="KsfAjccjcwBvy7qC1BYC-4" parent="BuUvHkD3C2r66v8NpPr0-2" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" value="&lt;div style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Warum gibt es Bibliotheken?&lt;/span&gt;&lt;/div&gt;&lt;div&gt;Weil React selbst sehr minimalistisch ist.&lt;/div&gt;&lt;div&gt;React kümmert sich nur um:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Komponenten&lt;/li&gt;&lt;li&gt;State&lt;/li&gt;&lt;li&gt;Rendering&lt;/li&gt;&lt;/ul&gt;Alles andere - Routing, HTTP-Requests, Formulare, UI-Design, Animationen - muss selbst hinzugefügt werden&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="260" x="25" y="80" as="geometry" />
