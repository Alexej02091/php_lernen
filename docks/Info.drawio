        <mxCell id="wo0p1ZfNdt3Z2teXgPPR-31" parent="wo0p1ZfNdt3Z2teXgPPR-29" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;fontSize=16;align=left;spacingLeft=5;verticalAlign=top;" value="&lt;div&gt;Ein Namespace ist ein Namensraum, der Klassen, Funktionen und Konstanten gruppiert.&lt;/div&gt;&lt;div&gt;Er löst zwei große Probleme:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Namenskollisionen vermeiden (z. B. zwei Klassen namens User aus verschiedenen Libraries)&lt;/li&gt;&lt;li&gt;Code strukturieren (ähnlich wie Ordner in einem Dateisystem)&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
