        <mxCell id="oUOb8mAdW-jnvmfY7ev4-1" parent="BuUvHkD3C2r66v8NpPr0-3" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="Warum braucht man useEffect?&lt;div&gt;Weil React-Komponenten rein sein sollen.&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Sie sollen nur UI rendern - Keine Netzwerkaufrufe direkt im Render-Prozess&lt;/span&gt;&lt;/div&gt;" vertex="1">
