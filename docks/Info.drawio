        <mxCell id="wGHetAYyMtZg8utDns9d-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Gute Frage, Alexej — und ich verspreche dir, wenn du diese zwei Zeilen verstehst, verstehst du &lt;strong&gt;den Kern deiner modularen Architektur&lt;/strong&gt;.&lt;br/&gt;Ich erkläre dir das so klar wie möglich.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="450" x="-230" y="410" as="geometry" />
        </mxCell>
        <mxCell id="wGHetAYyMtZg8utDns9d-2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="🧩 &lt;strong&gt;Der Code&lt;/strong&gt;&lt;div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;if (is_dir($moduleDir)) {&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; foreach (glob($moduleDir . &quot;/*Routes.php&quot;) as $routeFile) {&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; require_once $routeFile;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; }&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b&gt;}&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;font-weight: bold;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;font-weight: bold;&quot;&gt;Das ist der &lt;strong&gt;ModuleLoader&lt;/strong&gt;, der automatisch die passenden Routen für die aktuelle Rolle lädt.&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="450" x="-230" y="520" as="geometry" />
        </mxCell>
        <mxCell id="wGHetAYyMtZg8utDns9d-3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🔍 1. Was macht is_dir($moduleDir)?&lt;/div&gt;&lt;div&gt;is_dir() prüft:&lt;/div&gt;&lt;div&gt;👉 Gibt es einen Ordner für die aktuelle Rolle?&lt;/div&gt;&lt;div&gt;Beispiele:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Rolle = admin → sucht Ordner: src/Admin&lt;/li&gt;&lt;li&gt;Rolle = user → sucht Ordner: src/User&lt;/li&gt;&lt;li&gt;Rolle = guest → sucht Ordner: src/Guest (falls du einen hast)&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Wenn der Ordner existiert → weiter&lt;/div&gt;&lt;div&gt;Wenn nicht → nichts laden&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="450" x="-230" y="680" as="geometry" />
        </mxCell>
        <mxCell id="wGHetAYyMtZg8utDns9d-5" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🔍 2. Was macht glob($moduleDir . &quot;/*Routes.php&quot;)?&lt;/div&gt;&lt;div&gt;glob() sucht nach Dateien, die einem Muster entsprechen.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Hier:&lt;/div&gt;&lt;div&gt;&lt;div&gt;*Routes.php&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Das bedeutet:&lt;/div&gt;&lt;div&gt;👉 Lade alle Dateien, die auf „Routes.php“ enden.&lt;/div&gt;&lt;div&gt;Beispiele:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;AuthRoutes.php&lt;/li&gt;&lt;li&gt;UserRoutes.php&lt;/li&gt;&lt;li&gt;AdminRoutes.php&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Warum?&lt;/div&gt;&lt;div&gt;Weil jede Rolle eigene Routen hat.&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="230" width="450" x="-230" y="870" as="geometry" />
        </mxCell>
        <mxCell id="wGHetAYyMtZg8utDns9d-6" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🎯 Was bedeutet das alles zusammen?&lt;/div&gt;&lt;div&gt;Der Code bedeutet:&lt;/div&gt;&lt;div&gt;„Wenn es einen Ordner für die aktuelle Rolle gibt, lade automatisch alle Route‑Dateien dieser Rolle.“&lt;/div&gt;&lt;div&gt;Das ist automatische Modul‑Registrierung.&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="450" x="-230" y="1250" as="geometry" />
        </mxCell>
        <mxCell id="wGHetAYyMtZg8utDns9d-7" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🔍 3. Was macht require_once $routeFile?&lt;/div&gt;&lt;div&gt;Das ist der entscheidende Schritt:&lt;/div&gt;&lt;div&gt;👉 Die Route‑Datei wird geladen und registriert ihre Endpoints.&lt;/div&gt;&lt;div&gt;Beispiel: AdminRoutes.php könnte enthalten:&lt;/div&gt;&lt;div&gt;&lt;div&gt;$router-&amp;gt;get(&#39;/admin/dashboard&#39;, [AdminController::class, &#39;dashboard&#39;]);&lt;/div&gt;&lt;/div&gt;&lt;div&gt;Sobald die Datei geladen wird, sind diese Routen aktiv.&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="450" x="-230" y="1120" as="geometry" />
        </mxCell>
        <mxCell id="wGHetAYyMtZg8utDns9d-8" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🧠 Beispiel mit Rolle „admin“&lt;/div&gt;&lt;div&gt;Angenommen:&lt;/div&gt;&lt;div&gt;&lt;div&gt;$_SESSION[&#39;role&#39;] = &#39;admin&#39;;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Dann sucht der Loader:&lt;/div&gt;&lt;div&gt;&lt;div&gt;src/Admin/*Routes.php&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Er findet:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;AdminRoutes.php&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Und lädt sie:&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;b&gt;&lt;font style=&quot;color: rgb(0, 255, 0);&quot;&gt;require_once&lt;/font&gt;&lt;/b&gt; &quot;src/Admin/AdminRoutes.php&quot;;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;Jetzt sind alle Admin‑Routen aktiv.&lt;/div&gt;" vertex="1">
          <mxGeometry height="210" width="450" x="-230" y="1350" as="geometry" />
        </mxCell>
        <mxCell id="wGHetAYyMtZg8utDns9d-9" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;🚀 Warum ist das genial?&lt;/div&gt;&lt;div&gt;Weil du:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;keine if‑else‑Blöcke für Rollen brauchst&lt;/li&gt;&lt;li&gt;keine manuelle Registrierung von Modulen brauchst&lt;/li&gt;&lt;li&gt;neue Module einfach durch Dateien hinzufügen kannst&lt;/li&gt;&lt;li&gt;saubere Trennung zwischen Rollen hast&lt;/li&gt;&lt;li&gt;automatische Erweiterbarkeit bekommst&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Das ist echte, skalierbare Architektur.&lt;/div&gt;" vertex="1">
          <mxGeometry height="150" width="450" x="-230" y="1580" as="geometry" />
        </mxCell>
        <mxCell id="wGHetAYyMtZg8utDns9d-11" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="460" width="590" x="-360" y="-80" as="geometry" />
        </mxCell>
        <mxCell id="wGHetAYyMtZg8utDns9d-4" parent="wGHetAYyMtZg8utDns9d-11" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div style=&quot;color: rgb(187, 190, 191); background-color: rgb(18, 19, 20); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; line-height: 19px; white-space: pre;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;&amp;lt;?php&lt;/span&gt;&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: #ff7b72;&quot;&gt;namespace&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;App\Core&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: #ff7b72;&quot;&gt;use&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #79c0ff;&quot;&gt;App\Shared\&lt;/span&gt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;Session&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: #ff7b72;&quot;&gt;class&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;ModuleLoader&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;{&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;public&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #ff7b72;&quot;&gt;function&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d2a8ff;&quot;&gt;loadModules&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;()&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;&amp;nbsp; &amp;nbsp; {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;$role&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; = &lt;/span&gt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;Session&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;::&lt;/span&gt;&lt;span style=&quot;color: #d2a8ff;&quot;&gt;get&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&#39;role&#39;&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;) ?? &lt;/span&gt;&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&#39;guest&#39;&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;$moduleDir&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; = &lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;__DIR__&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;/../&quot;&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #dcdcaa;&quot;&gt;ucfirst&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;$role&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #c586c0;&quot;&gt;if&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; (&lt;/span&gt;&lt;span style=&quot;color: #dcdcaa;&quot;&gt;is_dir&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;$moduleDir&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;)) {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #c586c0;&quot;&gt;foreach&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; (&lt;/span&gt;&lt;span style=&quot;color: #dcdcaa;&quot;&gt;glob&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;$moduleDir&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #a5d6ff;&quot;&gt;&quot;/*Routes.php&quot;&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;) as &lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;$routeFile&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;) {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #c586c0;&quot;&gt;require_once&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;$routeFile&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;&amp;nbsp; &amp;nbsp; }&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;}&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
