        <mxCell id="KFwVIHRTOtqEWXRbHIaX-14" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" value="Kann Composer sie automatisch erzeugen?&lt;div&gt;✔️ Ja — mit:&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;composer init&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;div&gt;Dann stellt Composer dir Fragen:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Projektname?&lt;/li&gt;&lt;li&gt;Beschreibung?&lt;/li&gt;&lt;li&gt;PHP‑Version?&lt;/li&gt;&lt;li&gt;Autoload‑Namespace?&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Am Ende erzeugt Composer automatisch eine fertige composer.json.&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="190" width="320" x="190" y="1180" as="geometry" />
        </mxCell>
