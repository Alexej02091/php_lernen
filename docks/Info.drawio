        <mxCell id="wGHetAYyMtZg8utDns9d-12" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;Wenn du willst, zeige ich dir als Nächstes:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;wie deine AdminRoutes.php aussehen sollte&lt;/li&gt;&lt;li&gt;wie dein Router funktioniert&lt;/li&gt;&lt;li&gt;wie du Middleware (AuthGuard) einbaust&lt;/li&gt;&lt;li&gt;oder wie du dynamisch Controller lädst&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Sag einfach, wohin wir weitergehen.&lt;/div&gt;" vertex="1">
