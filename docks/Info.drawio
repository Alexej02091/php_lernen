        <mxCell id="UhoqVoWdSPM1nPK_Kb_X-26" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;fontSize=15;" value="&lt;div style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); display: inline !important;&quot;&gt;App startet minimal → schnell &amp;amp; sicher&lt;/div&gt;&lt;div style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Auth ist isoliert → saubere Kapselung&lt;/div&gt;&lt;div style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Rollen entscheiden → dynamische Modul‑Ladung&lt;/div&gt;&lt;div style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Module sind unabhängig → professionelle OOP‑Architektur&lt;/div&gt;&lt;div style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Erweiterbar → neue Rollen = neue Module&lt;/div&gt;" vertex="1">
