        <mxCell id="H_WizwPM-RSi_TVYo-0Q-4" parent="H_WizwPM-RSi_TVYo-0Q-28" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;width=240;height=30;" value="MySQLi API&amp;nbsp;" vertex="1">
