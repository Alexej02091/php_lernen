        <mxCell id="jShnli8X3TEjpVxSGF65-3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=5;" value="&lt;div&gt;&lt;span style=&quot;font-size: 15px;&quot;&gt;$app-&amp;gt;boot();&lt;/span&gt;&lt;/div&gt;&lt;div&gt;Du rufst die Methode boot() auf deinem App‑Objekt auf.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Typische Aufgaben einer boot()‑Methode:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Konfiguration laden&lt;/li&gt;&lt;li&gt;Services initialisieren&lt;/li&gt;&lt;li&gt;Datenbankverbindung herstellen&lt;/li&gt;&lt;li&gt;Sessions starten&lt;/li&gt;&lt;li&gt;Error‑Handler aktivieren&lt;/li&gt;&lt;li&gt;Routing vorbereiten&lt;/li&gt;&lt;li&gt;Dependency Container aufbauen&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;Kurz gesagt:&lt;/div&gt;&lt;div&gt;Die App wird vorbereitet, aber noch nicht ausgeführt.&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="310" x="490" y="-1160" as="geometry" />
        </mxCell>
